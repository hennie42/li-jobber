@implements IDisposable
@inject WorkspaceSession Workspace

<nav class="nav-cluster">
    <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
        <span>Start / Setup</span>
    </NavLink>
    <NavLink class="nav-item" href="/workspace/job-workbench" Match="NavLinkMatch.All">
        <span>Job Workbench</span>
    </NavLink>
    @if (Workspace.JobSets.Count > 0)
    {
        <ul class="nav-subitem-list">
            @foreach (var jobSet in Workspace.JobSets.OrderBy(j => j.SortOrder))
            {
                <li>
                    <NavLink class="nav-item nav-subitem" href="@($"/workspace/job-workbench/{jobSet.Id}")" title="@jobSet.Title">
                        <span class="@($"job-set-indicator job-set-indicator-{GetIndicatorState(jobSet)}")" aria-hidden="true"></span>
                        <span class="nav-subitem-label">@jobSet.Title</span>
                        <span class="@($"nav-subitem-mode nav-subitem-mode-{GetModeClass(jobSet.InputMode)}")" title="@FormatInputModeTitle(jobSet.InputMode)">@FormatInputModeShort(jobSet.InputMode)</span>
                    </NavLink>
                </li>
            }
        </ul>
    }
</nav>

@code {
    protected override void OnInitialized()
    {
        Workspace.Changed += HandleChanged;
    }

    public void Dispose()
    {
        Workspace.Changed -= HandleChanged;
    }

    private void HandleChanged() => InvokeAsync(StateHasChanged);

    private static string GetIndicatorState(JobSetSessionState jobSet) => jobSet.ProgressState switch
    {
        JobSetProgressState.Done => "done",
        JobSetProgressState.Running => "running",
        JobSetProgressState.Failed => "failed",
        _ => "idle"
    };

    private static string GetModeClass(JobSetInputMode mode) => mode switch
    {
        JobSetInputMode.PasteText => "text",
        _ => "url"
    };

    private static string FormatInputModeShort(JobSetInputMode mode) => mode switch
    {
        JobSetInputMode.PasteText => "TXT",
        _ => "URL"
    };

    private static string FormatInputModeTitle(JobSetInputMode mode) => mode switch
    {
        JobSetInputMode.PasteText => "Pasted job posting text",
        _ => "Linked job posting URLs"
    };
}
