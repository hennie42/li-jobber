@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JS
@inject OperationStatusService Operations

<div class="shell">
    <aside class="shell-sidebar">
        <div class="sidebar-floating-stack">
            <section class="sidebar-panel sidebar-navigation-panel">
                <div class="field-label">Navigation</div>
                <NavMenu />
            </section>

            <section class="sidebar-panel sidebar-monitor-panel">
                <div class="field-label">Reasoning Monitor</div>
                <div class="crt-monitor sidebar-crt-monitor">
                    <div class="crt-monitor-bezel sidebar-crt-bezel">
                        <div class="crt-monitor-header">
                            <span class="crt-monitor-led" aria-hidden="true"></span>
                            <div class="crt-monitor-badge">@GetSidebarMonitorBadgeText()</div>
                        </div>
                        <pre class="crt-monitor-screen sidebar-crt-screen @(HasSidebarThinkingText() ? null : "crt-monitor-screen-placeholder")" @ref="reasoningMonitorScreen">@GetSidebarThinkingText()</pre>
                        <div class="crt-monitor-footer">
                            <span class="crt-monitor-model-label">HN - Model 101010</span>
                            <span class="crt-monitor-vent" aria-hidden="true"></span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="sidebar-panel sidebar-monitor-panel sidebar-status-monitor-panel">
                <div class="field-label">Status Monitor</div>
                <div class="crt-monitor sidebar-crt-monitor sidebar-status-crt-monitor">
                    <div class="crt-monitor-bezel sidebar-crt-bezel">
                        <div class="crt-monitor-header">
                            <span class="crt-monitor-led" aria-hidden="true"></span>
                            <div class="crt-monitor-badge">@GetStatusMonitorBadgeText()</div>
                        </div>
                        <pre class="crt-monitor-screen sidebar-status-crt-screen @(HasStatusMonitorText() ? null : "crt-monitor-screen-placeholder")">@GetStatusMonitorText()</pre>
                        <div class="crt-monitor-footer">
                            <span class="crt-monitor-model-label">HN - Status 202020</span>
                            <span class="crt-monitor-vent" aria-hidden="true"></span>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <section class="sidebar-panel">
            <div class="field-label">Activity</div>
            <div class="activity-feed">
                @if (GetFinishedActivityEntries() is { Count: > 0 } entries)
                {
                    @foreach (var entry in entries)
                    {
                        <article class="activity-entry activity-@entry.Level">
                            <div class="activity-message">@entry.Message</div>
                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                            {
                                <div class="activity-detail">@entry.Detail</div>
                            }
                            <div class="activity-time">@entry.Timestamp.ToString("HH:mm:ss")@(entry.Duration is { } d ? $" ({d.Minutes}:{d.Seconds:D2})" : "")</div>
                        </article>
                    }
                }
                else
                {
                    <div class="sidebar-text">Finished activities will appear here.</div>
                }
            </div>
        </section>
    </aside>

    <main class="shell-content">
        <div class="content-frame">
            @Body
        </div>
    </main>
</div>

@code {
    private ElementReference reasoningMonitorScreen;
    private string? lastScrolledThinkingText;
    private System.Threading.Timer? sidebarElapsedTimer;
    private DateTimeOffset? sidebarOperationStartedAt;

    protected override void OnInitialized()
    {
        Operations.Changed += HandleChanged;
    }

    public void Dispose()
    {
        sidebarElapsedTimer?.Dispose();
        sidebarElapsedTimer = null;
        Operations.Changed -= HandleChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var currentThinkingText = GetSidebarThinkingRawText();
        if (string.IsNullOrWhiteSpace(currentThinkingText))
        {
            lastScrolledThinkingText = null;
            return;
        }

        if (string.Equals(currentThinkingText, lastScrolledThinkingText, StringComparison.Ordinal))
        {
            return;
        }

        lastScrolledThinkingText = currentThinkingText;

        try
        {
            await JS.InvokeVoidAsync("liCvWriterUi.scrollElementToBottom", reasoningMonitorScreen);
        }
        catch (JSDisconnectedException)
        {
            // Ignore disconnects during live updates.
        }
        catch (TaskCanceledException)
        {
            // Circuit may already be torn down.
        }
    }

    private IReadOnlyList<OperationStatusEntry> GetFinishedActivityEntries()
        => Operations.Entries
            .Where(static entry => !string.Equals(entry.Level, "busy", StringComparison.OrdinalIgnoreCase))
            .Take(6)
            .ToArray();

    private string? GetSidebarThinkingRawText()
    {
        if (!string.IsNullOrWhiteSpace(Operations.CurrentLlmTelemetry?.ThinkingContent)
            || !string.IsNullOrWhiteSpace(Operations.CurrentLlmTelemetry?.ThinkingPreview))
        {
            return Operations.CurrentLlmTelemetry?.ThinkingContent ?? Operations.CurrentLlmTelemetry?.ThinkingPreview;
        }

        return Operations.LastCompletedLlmTelemetry?.ThinkingContent ?? Operations.LastCompletedLlmTelemetry?.ThinkingPreview;
    }

    private bool HasSidebarThinkingText()
        => !string.IsNullOrWhiteSpace(GetSidebarThinkingRawText());

    private string GetSidebarThinkingText()
        => GetSidebarThinkingRawText()
            ?? "No reasoning text captured yet. Run a streamed LLM operation to light up this monitor.";

    private string? GetStatusMonitorRawText()
    {
        if (Operations.CurrentLlmTelemetry is { } current)
        {
            return BuildTelemetryStatusText(current);
        }

        if (Operations.LastCompletedLlmTelemetry is { } last)
        {
            return BuildTelemetryStatusText(last);
        }

        return Operations.IsBusy ? BuildBusyFallbackStatus() : null;
    }

    private static string BuildTelemetryStatusText(LlmOperationTelemetry telemetry)
        => string.IsNullOrWhiteSpace(telemetry.Detail)
            ? telemetry.Message
            : $"{telemetry.Message}\n{telemetry.Detail}";

    private bool HasStatusMonitorText()
        => !string.IsNullOrWhiteSpace(GetStatusMonitorRawText());

    private string GetStatusMonitorText()
        => GetStatusMonitorRawText()
            ?? "No streaming status captured yet. Run a streamed LLM operation to light up this monitor.";

    private string GetStatusMonitorBadgeText()
    {
        if (!HasStatusMonitorText())
        {
            return "Standby";
        }

        if (Operations.CurrentLlmTelemetry is not null || Operations.IsBusy)
        {
            return GetLiveBadgeWithTimer("Live status");
        }

        return "Last status";
    }

    private string GetLiveBadgeWithTimer(string label)
    {
        if (sidebarOperationStartedAt is null)
        {
            return label;
        }

        return $"{label} · {FormatSidebarDuration(DateTimeOffset.Now - sidebarOperationStartedAt.Value)}";
    }

    private static string FormatSidebarDuration(TimeSpan duration)
        => duration.TotalMinutes >= 1
            ? duration.ToString(@"m\:ss")
            : duration.ToString(@"s\.f\s");

    private string? BuildBusyFallbackStatus()
        => string.IsNullOrWhiteSpace(Operations.CurrentMessage)
            ? null
            : string.IsNullOrWhiteSpace(Operations.CurrentDetail)
                ? Operations.CurrentMessage
                : $"{Operations.CurrentMessage}\n{Operations.CurrentDetail}";

    private string GetSidebarMonitorBadgeText()
    {
        if (!HasSidebarThinkingText())
        {
            return "Standby";
        }

        return !string.IsNullOrWhiteSpace(Operations.CurrentLlmTelemetry?.ThinkingContent)
            || !string.IsNullOrWhiteSpace(Operations.CurrentLlmTelemetry?.ThinkingPreview)
            ? "Live feed"
            : "Last capture";
    }

    private void HandleChanged()
    {
        var isLive = Operations.IsBusy || Operations.CurrentLlmTelemetry is not null;

        if (isLive && sidebarElapsedTimer is null)
        {
            sidebarOperationStartedAt = DateTimeOffset.Now;
            sidebarElapsedTimer = new System.Threading.Timer(
                _ => _ = InvokeAsync(StateHasChanged),
                null,
                TimeSpan.FromSeconds(1),
                TimeSpan.FromSeconds(1));
        }
        else if (!isLive && sidebarElapsedTimer is not null)
        {
            sidebarElapsedTimer.Dispose();
            sidebarElapsedTimer = null;
            sidebarOperationStartedAt = null;
        }

        _ = InvokeAsync(StateHasChanged);
    }
}

