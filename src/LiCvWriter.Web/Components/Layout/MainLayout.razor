@inherits LayoutComponentBase
@implements IDisposable
@using LiCvWriter.Application.Models
@inject OperationStatusService Operations
@inject WorkspaceSession Workspace

<div class="shell">
    <aside class="shell-sidebar">
        <div class="brand-block">
            <div class="brand-kicker">LI CV Writer</div>
            <div class="brand-title">Local AI Resume Workbench</div>
            <p class="brand-text">Set up the session, then work each target role inside a single tabbed job workbench with local Ollama models.</p>
        </div>

        <section class="sidebar-panel">
            <div class="field-label">Navigation</div>
            <NavMenu />
        </section>

        <section class="sidebar-panel">
            <div class="field-label">Workspace</div>
            <div class="sidebar-metric">@(Workspace.CandidateProfile?.Name.FullName ?? "No profile loaded")</div>

            <div class="sidebar-group">
                <div class="sidebar-group-label">Session</div>
                <dl class="sidebar-grid">
                    <dt>LLM</dt>
                    <dd>@(Workspace.IsLlmReady ? $"{Workspace.SelectedLlmModel} · {FormatThinkingLevel(Workspace.SelectedThinkingLevel)}" : "Pending setup")</dd>
                    <dt>LinkedIn</dt>
                    <dd>@FormatLinkedInDataState(Workspace.LinkedInAuthorizationStatus)</dd>
                    <dt>Differentiators</dt>
                    <dd>@(Workspace.ApplicantDifferentiatorProfile.HasContent ? "Stored" : "Not set")</dd>
                </dl>
            </div>

            <div class="sidebar-group">
                <div class="sidebar-group-label">Active job</div>
                <dl class="sidebar-grid">
                    <dt>Tab</dt>
                    <dd>@Workspace.ActiveJobSet.Title</dd>
                    <dt>Role</dt>
                    <dd>@(Workspace.JobPosting?.RoleTitle ?? "—")</dd>
                    <dt>Language</dt>
                    <dd>@Workspace.ActiveJobSet.OutputLanguage</dd>
                    <dt>Evidence</dt>
                    <dd>@Workspace.GetActiveSelectedEvidenceCount()</dd>
                    <dt>Drafts</dt>
                    <dd>@Workspace.GeneratedDocuments.Count</dd>
                    <dt>Status</dt>
                    <dd>@FormatProgressState(Workspace.ActiveJobSet.ProgressState)</dd>
                </dl>
            </div>
        </section>

        <section class="sidebar-panel">
            <div class="field-label">Activity</div>
            <div class="sidebar-metric">@Operations.CurrentMessage</div>
            <div class="status-chip @(Operations.IsBusy ? "status-pending" : "status-ok")">
                @if (Operations.IsBusy)
                {
                    <span>Running @GetActivityElapsed()</span>
                }
                else
                {
                    <span>App-level status feed only. The UI stays interactive.</span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Operations.CurrentDetail))
            {
                <div class="sidebar-text">@Operations.CurrentDetail</div>
            }

            @{
                var telemetry = Operations.CurrentLlmTelemetry ?? Operations.LastCompletedLlmTelemetry;
            }
            @if (telemetry is not null)
            {
                <div class="field-label">@(Operations.CurrentLlmTelemetry is not null ? "Live telemetry" : "Last completed")</div>
                <dl class="key-value-grid compact-grid">
                    <dt>Phase</dt>
                    <dd>@telemetry.Message</dd>
                    <dt>Model</dt>
                    <dd>@telemetry.Model</dd>
                    <dt>Elapsed</dt>
                    <dd>@FormatDuration(telemetry.Elapsed)</dd>
                    @if (telemetry.PromptTokens is not null)
                    {
                        <dt>Prompt</dt>
                        <dd>@FormatTokenCount(telemetry.PromptTokens)</dd>
                    }
                    @if (telemetry.CompletionTokens is not null)
                    {
                        <dt>Completion</dt>
                        <dd>@FormatTokenCount(telemetry.CompletionTokens)</dd>
                    }
                    @if (telemetry.HasEstimatedRemaining)
                    {
                        <dt>ETA</dt>
                        <dd>@FormatDuration(telemetry.EstimatedRemaining)</dd>
                    }
                </dl>
            }

            <div class="activity-feed">
                @foreach (var entry in Operations.Entries.Take(6))
                {
                    <article class="activity-entry activity-@entry.Level">
                        <div class="activity-message">@entry.Message</div>
                        @if (!string.IsNullOrWhiteSpace(entry.Detail))
                        {
                            <div class="activity-detail">@entry.Detail</div>
                        }
                        <div class="activity-time">@entry.Timestamp.ToString("HH:mm:ss")@(entry.Duration is { } d ? $" ({d.Minutes}:{d.Seconds:D2})" : "")</div>
                    </article>
                }
            </div>
        </section>
    </aside>

    <main class="shell-content">
        <div class="content-frame">
            @Body
        </div>
    </main>
</div>

@code {
    private System.Threading.Timer? activityTimer;
    private bool wasBusy;

    protected override void OnInitialized()
    {
        Operations.Changed += HandleChanged;
        Workspace.Changed += HandleChanged;
    }

    public void Dispose()
    {
        activityTimer?.Dispose();
        Operations.Changed -= HandleChanged;
        Workspace.Changed -= HandleChanged;
    }

    private string GetActivityElapsed()
        => Operations.BusyStartedAt is { } started
            ? FormatDuration(DateTimeOffset.Now - started)
            : string.Empty;

    private void SyncActivityTimer()
    {
        if (Operations.IsBusy && !wasBusy)
        {
            activityTimer?.Dispose();
            activityTimer = new System.Threading.Timer(_ => _ = InvokeAsync(StateHasChanged), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
            wasBusy = true;
        }
        else if (!Operations.IsBusy && wasBusy)
        {
            activityTimer?.Dispose();
            activityTimer = null;
            wasBusy = false;
        }
    }

    private static string FormatThinkingLevel(string value)
        => string.IsNullOrWhiteSpace(value)
            ? "Pending"
            : char.ToUpperInvariant(value[0]) + value[1..];

    private static string FormatProgressState(JobSetProgressState progressState)
        => progressState switch
        {
            JobSetProgressState.Done => "Done",
            JobSetProgressState.Running => "Running",
            JobSetProgressState.Failed => "Needs attention",
            _ => "Not started"
        };

    private static string FormatLinkedInDataState(LinkedInAuthorizationStatus status)
        => status.IsAuthorized
            ? "Loaded"
            : "Pending DMA import";

    private static string FormatDuration(TimeSpan? duration)
    {
        if (duration is null)
        {
            return "Pending";
        }

        var value = duration.Value;
        return value.TotalMinutes >= 1
            ? value.ToString(@"m\:ss")
            : value.ToString(@"s\.f\s");
    }

    private static string FormatTokenCount(long? tokens)
        => tokens?.ToString("N0") ?? "Pending";

    private void HandleChanged()
    {
        SyncActivityTimer();
        _ = InvokeAsync(StateHasChanged);
    }
}

