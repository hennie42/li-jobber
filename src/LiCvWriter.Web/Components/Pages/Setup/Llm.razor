            FoundryAccelerationReadiness.PartiallyReady => "status-pending",
            FoundryAccelerationReadiness.NeedsRegistration => "status-pending",
            FoundryAccelerationReadiness.Unavailable => "status-warning",
            _ => "status-neutral"
        };

    private static bool ShouldShowFoundryAccelerationSection(FoundryAccelerationSnapshot acceleration)
        => OperatingSystem.IsWindows() || acceleration.IsSupported;

    private static string FormatExecutionProviderState(FoundryExecutionProviderInfo executionProvider)
        => executionProvider.IsRegistered ? "Registered" : "Discovered";

    private string GetFoundryExecutionProviderButtonLabel()
        => GetPreferredExecutionProviders().Count == 0
            ? "Register execution providers"
            : "Register preferred execution providers";

    private IReadOnlyList<string> GetPreferredExecutionProviders()
        => FoundryOptions.PreferredExecutionProviders
            .Where(static providerName => !string.IsNullOrWhiteSpace(providerName))
            .Select(static providerName => providerName.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private async Task<bool> TryAutoRegisterFoundryExecutionProvidersAsync(FoundryAccelerationSnapshot acceleration)
    {
        var preferredProviders = GetPreferredExecutionProviders();
        if (!FoundryOptions.AutoRegisterExecutionProviders
            || !OperatingSystem.IsWindows()
            || !acceleration.CanManageExecutionProviders
            || preferredProviders.Count == 0
            || preferredProviders.All(providerName => acceleration.ExecutionProviders.Any(executionProvider => executionProvider.IsRegistered && executionProvider.Name.Equals(providerName, StringComparison.OrdinalIgnoreCase))))
        {
            return false;
        }

        await Operations.RunAsync(
            "Registering Windows ML execution providers",
            string.Join(", ", preferredProviders),
            () => FoundryCatalogClient.RegisterExecutionProvidersAsync(
                preferredProviders,
                (providerName, percent) => Operations.UpdateCurrent(
                    "Registering Windows ML execution providers",
                    FoundryProgressFormatter.FormatDetail(providerName, percent))));

        await RefreshFoundrySnapshotAsync();
        return true;
    }

    private static string FormatLoadedState(LlmModelAvailability availability, string? selectedModel)
    {
        var model = string.IsNullOrWhiteSpace(selectedModel) ? availability.Model : selectedModel.Trim();
        if (string.IsNullOrWhiteSpace(model))
        {
            return "Unknown";
        }

        return availability.IsModelLoaded(model) ? "Yes" : "No";
    }

    private bool CanUseBenchmarkedModel(ModelBenchmarkResult benchmarkResult)
    {
        var benchmarkAvailability = benchmarkResult.Provider == LlmProviderKind.Foundry
            ? Workspace.FoundryAvailability
            : Workspace.OllamaAvailability;

        return benchmarkAvailability is not null
            && benchmarkAvailability.AvailableModels.Any(model => model.Equals(benchmarkResult.Model, StringComparison.OrdinalIgnoreCase));
    }

    private async Task UseBenchmarkedModelAsync(ModelBenchmarkResult benchmarkResult)
    {
        if (string.IsNullOrWhiteSpace(benchmarkResult.Model))
        {
            return;
        }

        try
        {
            if (selectedProvider != benchmarkResult.Provider)
            {
                selectedProvider = benchmarkResult.Provider;
                selectedActionModels.Clear();
                Workspace.SetLlmProviderSelection(selectedProvider);

                if (selectedProvider == LlmProviderKind.Foundry)
                {
                    await CheckFoundryAsync();
                }
                else
                {
                    await CheckOllamaAsync();
                }
            }

            if (!CanUseBenchmarkedModel(benchmarkResult))
            {
                Operations.Error(
                    $"Could not switch session model to {benchmarkResult.Model}.",
                    $"The {FormatProviderLabel(benchmarkResult.Provider)} model is no longer available locally.");
                return;
            }

            selectedModel = benchmarkResult.Model;
            await UseSessionLlmSettingsAsync();
            if (benchmarkResult.Provider == LlmProviderKind.Ollama && OllamaOptions.RunCapacityProbeOnModelSelect)
            {
                await RunCapacityProbeAsync(benchmarkResult.Model);
            }
        }
        catch (Exception exception)
        {
            Operations.Error($"Could not switch session model to {benchmarkResult.Model}.", exception.Message);
        }
    }

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);

    private void CancelBenchmark()
    {
        BenchmarkCoordinator.Cancel();
    }
}