            : $"{FormatProviderLabel(liveBenchmark.Provider)} benchmark is currently pressure-testing {liveBenchmark.CurrentModel}.";

    private string GetBenchmarkLiveDetail(ModelBenchmarkSession liveBenchmark)
        => $"{liveBenchmark.CompletedCount} of {liveBenchmark.TotalCount} complete in {FormatElapsedTime(DateTimeOffset.UtcNow - liveBenchmark.StartedUtc)}. {GetBenchmarkOperationSummary(liveBenchmark)}";

    private static string GetBenchmarkStageLabel(ModelBenchmarkSession liveBenchmark)
    {
        return liveBenchmark.CurrentPhase switch
        {
            ModelBenchmarkRunPhase.Preparing => "Preparing",
            ModelBenchmarkRunPhase.Warmup => "Warm-up",
            ModelBenchmarkRunPhase.Evaluating => "Evaluating",
            ModelBenchmarkRunPhase.Cleanup => "Cleanup",
            ModelBenchmarkRunPhase.Finalizing => "Finalizing",
            ModelBenchmarkRunPhase.Completed => "Completed",
            ModelBenchmarkRunPhase.Cancelled => "Cancelled",
            _ => "Working"
        };
    }

    private string GetBenchmarkOperationSummary(ModelBenchmarkSession liveBenchmark)
    {
        if (!string.IsNullOrWhiteSpace(liveBenchmark.CurrentFixtureDisplayName)
            && liveBenchmark.TotalFixtureCount > 0
            && liveBenchmark.CurrentPhase is ModelBenchmarkRunPhase.Evaluating or ModelBenchmarkRunPhase.Finalizing)
        {
            var fixtureOrdinal = liveBenchmark.CurrentFixtureNumber > 0
                ? liveBenchmark.CurrentFixtureNumber
                : Math.Min(liveBenchmark.CompletedFixtureCount + 1, liveBenchmark.TotalFixtureCount);
            return $"Fixture {fixtureOrdinal}/{liveBenchmark.TotalFixtureCount}: {liveBenchmark.CurrentFixtureDisplayName}. {liveBenchmark.CurrentDetail}";
        }

        if (!string.IsNullOrWhiteSpace(liveBenchmark.CurrentDetail))
        {
            return liveBenchmark.CurrentDetail;
        }

        return string.IsNullOrWhiteSpace(Operations.CurrentMessage)
            ? "Queue is moving through the selected models."
            : string.IsNullOrWhiteSpace(Operations.CurrentDetail)
                ? Operations.CurrentMessage
                : $"{Operations.CurrentMessage} {Operations.CurrentDetail}";
    }

    private static string GetBenchmarkProgressStyle(ModelBenchmarkSession liveBenchmark)
        => $"width: {GetBenchmarkProgressPercent(liveBenchmark):0.##}%";

    private static double GetBenchmarkProgressPercent(ModelBenchmarkSession liveBenchmark)
    {
        if (liveBenchmark.TotalCount <= 0)
        {
            return 0.0;
        }

        var inFlightBias = string.IsNullOrWhiteSpace(liveBenchmark.CurrentModel) ? 0.0 : 0.45;
        return Math.Clamp(((liveBenchmark.CompletedCount + inFlightBias) / liveBenchmark.TotalCount) * 100.0, 0.0, 100.0);
    }

    private static string GetBenchmarkProgressCaption(ModelBenchmarkSession liveBenchmark)
    {
        if (liveBenchmark.TotalFixtureCount > 0 && liveBenchmark.CurrentPhase == ModelBenchmarkRunPhase.Evaluating)
        {
            var fixtureOrdinal = liveBenchmark.CurrentFixtureNumber > 0
                ? liveBenchmark.CurrentFixtureNumber
                : Math.Min(liveBenchmark.CompletedFixtureCount + 1, liveBenchmark.TotalFixtureCount);
            return $"Fixture {fixtureOrdinal}/{liveBenchmark.TotalFixtureCount} is in flight for the current model.";
        }

        var remainingAfterCurrent = Math.Max(liveBenchmark.TotalCount - liveBenchmark.CompletedCount - (string.IsNullOrWhiteSpace(liveBenchmark.CurrentModel) ? 0 : 1), 0);
        return string.IsNullOrWhiteSpace(liveBenchmark.CurrentModel)
            ? "Final ranking and notes are being locked in."
            : remainingAfterCurrent == 0
                ? "This is the last model in the queue."
                : $"Current pass plus {remainingAfterCurrent} more model(s) still queued.";
    }

