    private IReadOnlyList<string> GetSelectableModelKeys()
        => IsOllamaSelected
            ? GetVisibleOllamaModels()
            : foundryCatalog?.Models.Select(static model => model.Alias).ToArray() ?? Array.Empty<string>();

    private IReadOnlyList<string> GetVisibleSelectableModelKeys()
        => IsOllamaSelected
            ? GetVisibleOllamaModels()
            : GetVisibleFoundryModels().Select(static model => model.Alias).ToArray();

    private IReadOnlyList<string> GetSelectedActionModels()
    {
        var validKeys = GetSelectableModelKeys().ToHashSet(StringComparer.OrdinalIgnoreCase);
        return selectedActionModels
            .Where(validKeys.Contains)
            .OrderBy(static value => value, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private IReadOnlyList<string> GetSelectedFoundryDownloadCandidates()
    {
        if (foundryCatalog is null)
        {
            return Array.Empty<string>();
        }

        return GetSelectedActionModels()
            .Where(alias => foundryCatalog.Models.Any(model => model.Alias.Equals(alias, StringComparison.OrdinalIgnoreCase) && !model.IsCached))
            .ToArray();
    }

    private void ReconcileSelectedActionModels()
    {
        var validKeys = GetSelectableModelKeys().ToHashSet(StringComparer.OrdinalIgnoreCase);
        selectedActionModels.RemoveWhere(model => !validKeys.Contains(model));
    }

    private bool IsModelSelected(string model)
        => selectedActionModels.Contains(model);

    private void SetModelSelection(string model, bool isSelected)
    {
        if (string.IsNullOrWhiteSpace(model))
        {
            return;
        }

        if (isSelected)
        {
            selectedActionModels.Add(model);
        }
        else
        {
            selectedActionModels.Remove(model);
        }
    }

    private void SelectAllVisibleModels()
    {
        foreach (var model in GetVisibleSelectableModelKeys())
        {
            selectedActionModels.Add(model);
        }
    }

    private void ClearSelectedModels()
    {
        foreach (var model in GetSelectableModelKeys())
        {
            selectedActionModels.Remove(model);
        }
    }

    private string GetSelectedModelsStatusMessage()
    {
        var selected = GetSelectedActionModels();
        if (selected.Count == 0)
        {
            return "No models selected for batch actions.";
        }

        if (IsOllamaSelected)
        {
            return $"Selected models: {selected.Count}.";
        }

        var downloadCandidates = GetSelectedFoundryDownloadCandidates().Count;
        return downloadCandidates == 0
            ? $"Selected models: {selected.Count}. All selected Foundry models are already cached."
            : $"Selected models: {selected.Count}. {downloadCandidates} selected model(s) will be downloaded before use.";
    }

    private IReadOnlyList<FoundryCatalogModel> GetVisibleFoundryModels()
    {
        if (foundryCatalog is null)
        {
            return Array.Empty<FoundryCatalogModel>();
        }

        if (string.IsNullOrWhiteSpace(foundryModelFilter))
        {
            return foundryCatalog.Models;
        }

        var filter = foundryModelFilter.Trim();
        return foundryCatalog.Models
            .Where(model => model.Alias.Contains(filter, StringComparison.OrdinalIgnoreCase)
                || model.DisplayName.Contains(filter, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

