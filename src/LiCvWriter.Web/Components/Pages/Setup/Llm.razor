@page "/setup/llm"
@implements IDisposable
@inject ILlmClient LlmClient
@inject IFoundryCatalogClient FoundryCatalogClient
@inject FoundryOptions FoundryOptions
@inject OllamaOptions OllamaOptions
@inject OperationStatusService Operations
@inject WorkspaceSession Workspace
@inject OllamaCapacityProbe CapacityProbe
@inject ModelBenchmarkCoordinator BenchmarkCoordinator

<PageTitle>Setup / LLM</PageTitle>

<section class="card-panel setup-header">
    <div class="setup-header-row">
        <div>
            <div class="field-label">Setup</div>
            <h2>LLM selection and related work</h2>
            <p class="muted-text">Choose the local provider, keep session model selection separate from batch actions, and run the same selection-driven workflow across providers.</p>
        </div>
        <div class="button-row">
            <a class="secondary-button" href="/">Back to overview</a>
            <a class="primary-button setup-header-cta" href="/workspace/job-workbench">Open Job Workbench -&gt;</a>
        </div>
    </div>
</section>

<section class="card-panel stack-gap">
    <div class="field-label">Local LLM setup</div>
    <div class="status-chip @(Workspace.IsLlmReady ? "status-ok" : "status-pending")">
        @GetStep1StatusMessage()
    </div>

    @{
        var capacityVerdict = Workspace.CurrentCapacityVerdict;
        var availableSessionModels = GetAvailableSessionModels();
    }

    @if (IsOllamaSelected && capacityVerdict is not null)
    {
        <div class="status-chip @CapacityChipClass(capacityVerdict.Fit)" title="@string.Join(" \u2022 ", capacityVerdict.Notes)">
            Hardware fit: @capacityVerdict.Fit - @capacityVerdict.Headline
        </div>
    }

    <p class="muted-text">@GetProviderSetupIntro()</p>

    <label class="field-label" for="llmProvider">Local LLM provider</label>
    <select id="llmProvider" class="text-input" @bind="selectedProvider" @bind:after="HandleProviderSelectionChangedAsync" disabled="@IsProviderSelectionBusy">
        @foreach (var provider in AvailableLlmProviders)
        {
            <option value="@provider">@FormatProviderLabel(provider)</option>
        }
    </select>

    <section class="details-card stack-gap">
        <div class="field-label">Session model</div>
        @if (availableSessionModels.Count > 0)
        {
            <label class="field-label" for="sessionModel">Session model</label>
            <select id="sessionModel" class="text-input" @bind="selectedModel" disabled="@IsModelSelectionBusy">
                @foreach (var model in availableSessionModels)
                {
                    <option value="@model">@model</option>
                }
            </select>

            <label class="field-label" for="thinkingLevel">Thinking level</label>
            <select id="thinkingLevel" class="text-input" @bind="selectedThinkingLevel" disabled="@IsModelSelectionBusy">
                @foreach (var level in ThinkingLevels)
                {
                    <option value="@level">@FormatThinkingLevel(level)</option>
                }
            </select>

            <div class="button-row">
                <button class="primary-button" @onclick="UseSessionLlmSettingsAsync" disabled="@(!CanSaveSessionLlmSettings)">Use session LLM settings</button>
                <button class="secondary-button" @onclick="RefreshSelectedProviderAsync" disabled="@IsProviderRefreshBusy">@GetRefreshInventoryButtonLabel()</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(selectedModel))
            {
                <div class="status-chip @(Workspace.IsLlmReady ? "status-ok" : "status-pending")">
                    Selected @GetSelectedProviderLabel() model: @selectedModel
                </div>
            }
        }
        else
        {
            <p class="muted-text">@GetSessionModelPendingMessage()</p>
            <div class="button-row">
                <button class="primary-button" @onclick="RefreshSelectedProviderAsync" disabled="@IsProviderRefreshBusy">@GetRefreshInventoryButtonLabel()</button>
            </div>
        }
    </section>

    @if (IsOllamaSelected)
    {
        var visibleOllamaModels = GetVisibleOllamaModels();
        @if (availability is not null)
        {
            <section class="details-card stack-gap">
                <div class="field-label">Model inventory</div>
                <dl class="key-value-grid compact-grid">
                    <dt>Version</dt>
                    <dd>@availability.Version</dd>
                    <dt>Configured default</dt>
                    <dd>@OllamaOptions.Model</dd>
                    <dt>Available models</dt>
                    <dd>@availability.AvailableModels.Count</dd>
                    <dt>Loaded models</dt>
                    <dd>@availability.EffectiveRunningModels.Count</dd>
                    <dt>Session model loaded</dt>
                    <dd>@FormatLoadedState(availability, selectedModel)</dd>
                </dl>

                <p class="muted-text">Loaded now: @FormatRunningModels(availability)</p>

                @if (visibleOllamaModels.Count > 0)
                {
                    <table class="compact-grid setup-list-table">
                        <thead>
                            <tr><th></th><th>Model</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in visibleOllamaModels.Select((model, index) => new { model, index }))
                            {
                                <tr class="@GetSetupListRowClass(item.index)">
                                    <td>
                                        <input type="checkbox"
                                               checked="@IsModelSelected(item.model)"
                                               @onchange="args => SetModelSelection(item.model, args.Value is bool isSelected && isSelected)"
                                               disabled="@IsModelSelectionBusy" />
                                    </td>
                                    <td>@item.model</td>
                                    <td>@GetOllamaModelState(availability, item.model)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="muted-text">Ollama responded, but no models were returned from the tags endpoint.</p>
                }
            </section>
        }
        else
        {
            <p class="muted-text">Run the Ollama check to load the local model list before saving the session settings.</p>
        }
    }
    else
    {
        var visibleFoundryModels = GetVisibleFoundryModels();
        @if (foundryCatalog is not null)
        {
            <section class="details-card stack-gap">
                <div class="field-label">Model inventory</div>
                <dl class="key-value-grid compact-grid">
                    <dt>SDK version</dt>
                    <dd>@foundryCatalog.Availability.Version</dd>
                    <dt>Configured default</dt>
                    <dd>@FoundryOptions.DefaultModelAlias</dd>
                    <dt>Catalog models</dt>
                    <dd>@foundryCatalog.Models.Count</dd>
                    <dt>Cached models</dt>
                    <dd>@foundryCatalog.Availability.AvailableModels.Count</dd>
                    <dt>Loaded models</dt>
                    <dd>@foundryCatalog.Availability.EffectiveRunningModels.Count</dd>
                    <dt>Session model loaded</dt>
                    <dd>@FormatLoadedState(foundryCatalog.Availability, selectedModel)</dd>
                </dl>

                <p class="muted-text">Cached models are ready for session use. Uncached models can be selected for batch download or selected-model benchmarking.</p>

                @if (ShouldShowFoundryAccelerationSection(foundryCatalog.Acceleration))
                {
                    <div class="field-label">Windows ML acceleration</div>
                    <div class="status-chip @GetFoundryAccelerationChipClass(foundryCatalog.Acceleration)">
                        @foundryCatalog.Acceleration.StatusMessage
                    </div>

                    @if (foundryCatalog.Acceleration.ExecutionProviders.Count > 0)
                    {
                        <table class="compact-grid setup-list-table">
                            <thead>
                                <tr><th>Execution provider</th><th>Status</th></tr>
                            </thead>
                            <tbody>
                                    @foreach (var item in foundryCatalog.Acceleration.ExecutionProviders.Select((executionProvider, index) => new { executionProvider, index }))
                                {
                                        <tr class="@GetSetupListRowClass(item.index)">
                                            <td>@item.executionProvider.DisplayName</td>
                                            <td>@FormatExecutionProviderState(item.executionProvider)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (foundryCatalog.Acceleration.IsEnabled)
                    {
                        <p class="muted-text">No execution providers are currently reported by the installed Foundry runtime.</p>
                    }

                    @if (foundryCatalog.Acceleration.CanManageExecutionProviders)
                    {
                        <div class="button-row">
                            <button class="secondary-button" @onclick="RegisterFoundryExecutionProvidersAsync" disabled="@IsFoundryBusy">
                                @(isRegisteringFoundryExecutionProviders ? "Registering..." : GetFoundryExecutionProviderButtonLabel())
                            </button>
                        </div>
                    }
                }

                <label class="field-label" for="foundryModelFilter">Filter catalog</label>
                <input id="foundryModelFilter" class="text-input" @bind="foundryModelFilter" placeholder="Filter by alias or display name" disabled="@IsModelSelectionBusy" />

                @if (visibleFoundryModels.Count == 0)
                {
                    <p class="muted-text">No Foundry catalog models match the current filter.</p>
                }
                else
                {
                    <table class="compact-grid setup-list-table">
                        <thead>
                            <tr><th></th><th>Model</th><th>Alias</th><th>Size (GB)</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var item in visibleFoundryModels.Select((model, index) => new { model, index }))
                            {
                                <tr class="@GetSetupListRowClass(item.index)">
                                    <td>
                                        <input type="checkbox"
                                               checked="@IsModelSelected(item.model.Alias)"
                                               @onchange="args => SetModelSelection(item.model.Alias, args.Value is bool isSelected && isSelected)"
                                               disabled="@IsModelSelectionBusy" />
                                    </td>
                                    <td>
                                        <strong>@item.model.DisplayName</strong>
                                        <div class="setup-list-detail">@GetFoundryModelDetail(item.model)</div>
                                    </td>
                                    <td>@item.model.Alias</td>
                                    <td>@FormatFoundryModelSize(item.model)</td>
                                    <td>@GetFoundryModelState(item.model)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </section>
        }
        else
        {
            <p class="muted-text">Load the Foundry catalog to see cached models and the full list of selectable aliases.</p>
        }
    }

    <section class="details-card stack-gap">
        <div class="field-label">Model actions</div>
        <p class="muted-text">Model selection happens above. Batch actions below always work from the current checkbox selection, so the layout stays consistent across providers.</p>

        <div class="button-row">
            <button class="secondary-button" @onclick="SelectAllVisibleModels" disabled="@(!CanSelectVisibleModels)">Select all visible</button>
            <button class="secondary-button" @onclick="ClearSelectedModels" disabled="@(!HasSelectedModels)">Select none</button>
            <button class="secondary-button" @onclick="DownloadSelectedModelsAsync" disabled="@(!CanDownloadSelectedModels)">@(isDownloadingFoundryModel ? "Downloading..." : "Download selected")</button>
            <button class="primary-button" @onclick="StartBenchmarkSelectedAsync" disabled="@(!CanBenchmarkSelectedModels)">@(BenchmarkCoordinator.IsRunning ? "Benchmarking..." : "Benchmark selected")</button>
            @if (BenchmarkCoordinator.IsRunning)
            {
                <button class="link-button" @onclick="CancelBenchmark">Cancel benchmark</button>
            }
        </div>

        <div class="status-chip @(HasSelectedModels ? "status-ok" : "status-pending")">
            @GetSelectedModelsStatusMessage()
        </div>

        @if (IsOllamaSelected)
        {
            <p class="muted-text">Ollama model installation and removal stay outside the app, but the same selection and selected-model benchmark flow applies here.</p>
        }
        else
        {
            <label>
                <input type="checkbox" @bind="removeTooLargeFoundryModelsAfterBenchmark" disabled="@IsModelSelectionBusy" />
                Remove models classified as too large for interactive use after benchmark.
            </label>
            <p class="muted-text">The benchmark result stays visible even if a Foundry model is removed from the local cache after benchmarking.</p>
            @if (!FoundryOptions.AllowDownloads)
            {
                <p class="muted-text">Foundry downloads are disabled in configuration, so only already cached models can be benchmarked or used.</p>
            }
        }
    </section>

    @if (!IsOllamaSelected && foundryCatalog is not null)
    {
        <section class="details-card stack-gap foundry-guidance-panel">
            <div class="field-label">Foundry performance notes</div>
            <div class="benchmark-guidance-grid">
                <article class="benchmark-guidance-card">
                    <h3>Hardware path</h3>
                    <p>@GetFoundryHardwareGuidance(foundryCatalog)</p>
                </article>
                <article class="benchmark-guidance-card">
                    <h3>Alias behavior</h3>
                    <p>@GetFoundryAliasGuidance()</p>
                </article>
                <article class="benchmark-guidance-card">
                    <h3>Tuning in this app</h3>
                    <p>@GetFoundryTuningGuidance(foundryCatalog)</p>
                </article>
            </div>
        </section>
    }

    @if (BenchmarkCoordinator.Current is { IsRunning: true } liveBenchmark)
    {
        var recentBenchmarkEntries = GetRecentBenchmarkActivityEntries();
        <section class="details-card benchmark-live-rail stack-gap">
            <div class="benchmark-live-header">
                <div>
                    <div class="field-label">Live benchmark run</div>
                    <h3>@GetBenchmarkLiveHeadline(liveBenchmark)</h3>
                    <p class="muted-text">@GetBenchmarkLiveDetail(liveBenchmark)</p>
                </div>
                <div class="benchmark-stage-pill">@GetBenchmarkStageLabel(liveBenchmark)</div>
            </div>

            <div class="benchmark-progress-track" aria-hidden="true">
                <div class="benchmark-progress-fill benchmark-progress-fill-live" style="@GetBenchmarkProgressStyle(liveBenchmark)"></div>
            </div>

            <div class="benchmark-live-grid">
                <article class="benchmark-live-card">
                    <span class="benchmark-live-label">Current model</span>
                    <strong>@(liveBenchmark.CurrentModel ?? "Wrapping up")</strong>
                    <div class="benchmark-live-detail">@GetBenchmarkOperationSummary(liveBenchmark)</div>
                </article>
                <article class="benchmark-live-card">
                    <span class="benchmark-live-label">Queue progress</span>
                    <strong>@liveBenchmark.CompletedCount / @liveBenchmark.TotalCount complete</strong>
                    <div class="benchmark-live-detail">@GetBenchmarkProgressCaption(liveBenchmark)</div>
                </article>
                <article class="benchmark-live-card">
                    <span class="benchmark-live-label">Cleanup policy</span>
                    <strong>@GetBenchmarkCleanupPolicyLabel(liveBenchmark)</strong>
                    <div class="benchmark-live-detail">@GetBenchmarkCleanupPolicyDetail(liveBenchmark)</div>
                </article>
            </div>

            @if (recentBenchmarkEntries.Count > 0)
            {
                <div class="benchmark-event-strip">
                    @foreach (var entry in recentBenchmarkEntries)
                    {
                        <article class="benchmark-event-pill benchmark-event-pill-@entry.Level">
                            <div class="benchmark-event-message">@entry.Message</div>
                            @if (!string.IsNullOrWhiteSpace(entry.Detail))
                            {
                                <div class="benchmark-event-detail">@entry.Detail</div>
                            }
                        </article>
                    }
                </div>
            }

            @if (liveBenchmark.Results.Count > 0)
            {
                <section class="details-card benchmark-summary-shell stack-gap">
                    <div class="benchmark-live-header">
                        <div>
                            <div class="field-label">Live results so far</div>
                            <h3>@GetBenchmarkLiveResultsHeadline(liveBenchmark)</h3>
                            <p class="muted-text">@GetBenchmarkLiveResultsDetail(liveBenchmark)</p>
                        </div>
                        <div class="status-chip status-pending">
                            Live benchmark: @FormatProviderLabel(liveBenchmark.Provider) - @liveBenchmark.Results.Count of @liveBenchmark.TotalCount model(s) ranked
                        </div>
                    </div>
                </section>

                <table class="compact-grid setup-list-table">
                    <thead>
                        <tr><th>#</th><th>Provider</th><th>Model</th><th>Overall</th><th>Quality</th><th>Decode tok/s</th><th>Fit</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in liveBenchmark.Results.Select((benchmarkRow, index) => new { benchmarkRow, index }))
                        {
                            <tr class="@GetSetupListRowClass(item.index)">
                                <td>@item.benchmarkRow.Rank</td>
                                <td>@FormatProviderLabel(item.benchmarkRow.Provider)</td>
                                <td>@item.benchmarkRow.Model</td>
                                <td>@(item.benchmarkRow.Succeeded ? item.benchmarkRow.OverallScore.ToString("0.00") : "-")</td>
                                <td>@(item.benchmarkRow.Succeeded ? item.benchmarkRow.QualityScore.ToString("0.00") : "-")</td>
                                <td>@(item.benchmarkRow.DecodeTokensPerSecond is { } tps ? tps.ToString("0.0") : "-")</td>
                                <td title="@string.Join(" \u2022 ", item.benchmarkRow.Notes)">@(item.benchmarkRow.Succeeded ? item.benchmarkRow.Fit.ToString() : (item.benchmarkRow.FailedReason ?? "failed"))</td>
                                <td>
                                    @if (item.benchmarkRow.Succeeded && CanUseBenchmarkedModel(item.benchmarkRow))
                                    {
                                        <button class="link-button" @onclick="() => UseBenchmarkedModelAsync(item.benchmarkRow)">Use</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    }
    else if (BenchmarkCoordinator.Last is { Results.Count: > 0 } lastBenchmark)
    {
        var topBenchmarkResult = GetTopBenchmarkResult(lastBenchmark);
        <section class="details-card benchmark-summary-shell stack-gap">
            <div class="benchmark-live-header">
                <div>
                    <div class="field-label">Benchmark snapshot</div>
                    <h3>@GetBenchmarkSummaryHeadline(lastBenchmark)</h3>
                    <p class="muted-text">@GetBenchmarkSummaryDetail(lastBenchmark)</p>
                </div>
                <div class="status-chip @(lastBenchmark.IsCancelled ? "status-pending" : "status-ok")">
                    Last benchmark: @FormatProviderLabel(lastBenchmark.Provider) - @lastBenchmark.Results.Count model(s)
                    @(lastBenchmark.IsCancelled ? " (cancelled)" : string.Empty)
                    - completed @lastBenchmark.CompletedUtc?.LocalDateTime.ToString("g")
                </div>
            </div>

            <div class="benchmark-summary-grid">
                <article class="benchmark-highlight-card">
                    <span class="benchmark-live-label">Top model</span>
                    @if (topBenchmarkResult is not null)
                    {
                        <strong>@topBenchmarkResult.Model</strong>
                        @if (topBenchmarkResult.Succeeded)
                        {
                            <div class="benchmark-score-line">
                                <span>Overall @topBenchmarkResult.OverallScore.ToString("0.00")</span>
                                <span>Quality @topBenchmarkResult.QualityScore.ToString("0.00")</span>
                                <span>Decode @FormatDecodeSpeed(topBenchmarkResult)</span>
                            </div>
                            <div class="benchmark-live-detail">Fit: @topBenchmarkResult.Fit</div>
                        }
                        else
                        {
                            <div class="benchmark-live-detail">@topBenchmarkResult.FailedReason</div>
                        }
                    }
                </article>

                <article class="benchmark-stat-card">
                    <span class="benchmark-live-label">Usable results</span>
                    <strong>@CountSucceededBenchmarks(lastBenchmark)</strong>
                    <div class="benchmark-live-detail">models returned benchmark data without a hard failure.</div>
                </article>

                <article class="benchmark-stat-card">
                    <span class="benchmark-live-label">Cleanup actions</span>
                    <strong>@CountRemovedBenchmarkedModels(lastBenchmark)</strong>
                    <div class="benchmark-live-detail">model(s) removed, @CountCleanupWarningBenchmarks(lastBenchmark) warning(s) preserved in notes.</div>
                </article>
            </div>
        </section>

        <table class="compact-grid setup-list-table">
            <thead>
                <tr><th>#</th><th>Provider</th><th>Model</th><th>Overall</th><th>Quality</th><th>Decode tok/s</th><th>Fit</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var item in lastBenchmark.Results.Select((benchmarkRow, index) => new { benchmarkRow, index }))
                {
                    <tr class="@GetSetupListRowClass(item.index)">
                        <td>@item.benchmarkRow.Rank</td>
                        <td>@FormatProviderLabel(item.benchmarkRow.Provider)</td>
                        <td>@item.benchmarkRow.Model</td>
                        <td>@(item.benchmarkRow.Succeeded ? item.benchmarkRow.OverallScore.ToString("0.00") : "-")</td>
                        <td>@(item.benchmarkRow.Succeeded ? item.benchmarkRow.QualityScore.ToString("0.00") : "-")</td>
                        <td>@(item.benchmarkRow.DecodeTokensPerSecond is { } tps ? tps.ToString("0.0") : "-")</td>
                        <td title="@string.Join(" \u2022 ", item.benchmarkRow.Notes)">@(item.benchmarkRow.Succeeded ? item.benchmarkRow.Fit.ToString() : (item.benchmarkRow.FailedReason ?? "failed"))</td>
                        <td>
                            @if (item.benchmarkRow.Succeeded && CanUseBenchmarkedModel(item.benchmarkRow))
                            {
                                <button class="link-button" @onclick="() => UseBenchmarkedModelAsync(item.benchmarkRow)">Use</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (Workspace.HasStartedLlmWork)
    {
        <p class="muted-text">Updated session model and thinking changes apply to future LLM operations. Re-run any completed analysis or draft generation that you want refreshed with the new settings.</p>
    }

    @if (GetFoundrySetupDiagnostic() is { } foundrySetupDiagnostic)
    {
        <div class="message error foundry-setup-error">
            <strong>@foundrySetupDiagnostic.Summary</strong>
            <p class="foundry-setup-error-guidance">@foundrySetupDiagnostic.Guidance</p>
            <ol class="foundry-setup-error-steps">
                @foreach (var nextStep in foundrySetupDiagnostic.NextSteps)
                {
                    <li>@nextStep</li>
                }
            </ol>
            <details class="foundry-setup-error-details">
                <summary>Technical detail</summary>
                <pre>@llmErrorMessage</pre>
            </details>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(llmErrorMessage))
    {
        <div class="message error">@llmErrorMessage</div>
    }
</section>

@code {
    private static readonly string[] ThinkingLevels = ["low", "medium", "high"];
    private static readonly LlmProviderKind[] AvailableLlmProviders = [LlmProviderKind.Ollama, LlmProviderKind.Foundry];

    private readonly HashSet<string> selectedActionModels = new(StringComparer.OrdinalIgnoreCase);
    private bool isCheckingOllama;
    private bool isCheckingFoundry;
    private bool isDownloadingFoundryModel;
    private bool isRegisteringFoundryExecutionProviders;
    private bool removeTooLargeFoundryModelsAfterBenchmark = true;
    private string? llmErrorMessage;
    private LlmModelAvailability? availability;
    private FoundryCatalogSnapshot? foundryCatalog;
    private LlmProviderKind selectedProvider = LlmProviderKind.Ollama;
    private string selectedModel = string.Empty;
    private string selectedThinkingLevel = "medium";
    private string downloadingFoundryAlias = string.Empty;
    private string foundryModelFilter = string.Empty;

    private bool CanSaveSessionLlmSettings => !IsModelSelectionBusy
        && GetAvailableSessionModels().Count > 0
        && !string.IsNullOrWhiteSpace(selectedModel);

    private bool IsOllamaSelected => selectedProvider == LlmProviderKind.Ollama;

    private bool IsProviderSelectionBusy => isCheckingOllama
        || isCheckingFoundry
        || isDownloadingFoundryModel
        || isRegisteringFoundryExecutionProviders
        || BenchmarkCoordinator.IsRunning;

    private bool IsModelSelectionBusy => IsProviderSelectionBusy;

    private bool IsProviderRefreshBusy => IsOllamaSelected ? isCheckingOllama : isCheckingFoundry;

    private bool IsFoundryBusy => isCheckingFoundry || isDownloadingFoundryModel || isRegisteringFoundryExecutionProviders;

    private bool HasSelectedModels => GetSelectedActionModels().Count > 0;

    private bool CanSelectVisibleModels => !IsModelSelectionBusy && GetVisibleSelectableModelKeys().Count > 0;

    private bool CanDownloadSelectedModels => !IsOllamaSelected
        && !IsModelSelectionBusy
        && FoundryOptions.AllowDownloads
        && GetSelectedFoundryDownloadCandidates().Count > 0;

    private bool CanBenchmarkSelectedModels => !IsModelSelectionBusy
        && HasSelectedModels
        && (IsOllamaSelected || FoundryOptions.AllowDownloads || GetSelectedFoundryDownloadCandidates().Count == 0);

    protected override void OnInitialized()
    {
        Operations.Changed += HandleChanged;
        BenchmarkCoordinator.Changed += HandleChanged;
        selectedProvider = Workspace.SelectedLlmProvider;
        availability = Workspace.OllamaAvailability;
        selectedModel = Workspace.SelectedLlmModel;
        selectedThinkingLevel = Workspace.SelectedThinkingLevel;
    }

    public void Dispose()
    {
        Operations.Changed -= HandleChanged;
        BenchmarkCoordinator.Changed -= HandleChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsOllamaSelected && availability is null)
        {
            await CheckOllamaAsync();
            StateHasChanged();
        }
        else if (firstRender && !IsOllamaSelected && foundryCatalog is null)
        {
            await CheckFoundryAsync();
            StateHasChanged();
        }
    }

    private async Task HandleProviderSelectionChangedAsync()
    {
        llmErrorMessage = null;
        availability = Workspace.OllamaAvailability;
        selectedActionModels.Clear();
        Workspace.SetLlmProviderSelection(selectedProvider);
        selectedModel = Workspace.SelectedLlmModel;
        selectedThinkingLevel = Workspace.SelectedThinkingLevel;

        if (IsOllamaSelected)
        {
            if (availability is null)
            {
                await CheckOllamaAsync();
                return;
            }

            Operations.Info("Ollama selected.", "Choose a session model, then use the shared action section to benchmark the checked models.");
        }
        else
        {
            if (foundryCatalog is null)
            {
                await CheckFoundryAsync();
                return;
            }

            Operations.Info("Microsoft Foundry Local selected.", "Choose a cached session model, then use the shared action section to download or benchmark the checked models.");
        }
    }

    private async Task CheckOllamaAsync()
    {
        if (!IsOllamaSelected)
        {
            return;
        }

        llmErrorMessage = null;
        isCheckingOllama = true;

        try
        {
            availability = await Operations.RunAsync(
                "Checking Ollama access",
                OllamaOptions.BaseUrl,
                () => LlmClient.VerifyModelAvailabilityAsync());

            Workspace.SetOllamaAvailability(availability);
            selectedModel = Workspace.SelectedLlmModel;
            selectedThinkingLevel = Workspace.SelectedThinkingLevel;
            ReconcileSelectedActionModels();
            Operations.Success(
                "Ollama is reachable.",
                $"Discovered {availability.AvailableModels.Count} models; loaded now: {availability.EffectiveRunningModels.Count}.");
        }
        catch (Exception exception)
        {
            llmErrorMessage = exception.Message;
            Operations.Error("Ollama access check failed.", exception.Message);
        }
        finally
        {
            isCheckingOllama = false;
        }
    }

    private async Task CheckFoundryAsync()
    {
        if (IsOllamaSelected)
        {
            return;
        }

        llmErrorMessage = null;
        isCheckingFoundry = true;

        try
        {
            foundryCatalog = await Operations.RunAsync(
                "Loading Foundry Local catalog",
                FoundryOptions.DefaultModelAlias,
                () => FoundryCatalogClient.GetSnapshotAsync());

            Workspace.SetFoundryAvailability(foundryCatalog.Availability);
            selectedModel = Workspace.SelectedLlmModel;
            selectedThinkingLevel = Workspace.SelectedThinkingLevel;
            ReconcileSelectedActionModels();

            if (await TryAutoRegisterFoundryExecutionProvidersAsync(foundryCatalog.Acceleration))
            {
                Workspace.SetFoundryAvailability(foundryCatalog.Availability);
                selectedModel = Workspace.SelectedLlmModel;
                selectedThinkingLevel = Workspace.SelectedThinkingLevel;
                ReconcileSelectedActionModels();
            }

            var accelerationDetail = ShouldShowFoundryAccelerationSection(foundryCatalog.Acceleration)
                ? $" {foundryCatalog.Acceleration.StatusMessage}"
                : string.Empty;
            Operations.Success(
                "Foundry Local catalog loaded.",
                $"Catalog: {foundryCatalog.Models.Count} models; cached: {foundryCatalog.Availability.AvailableModels.Count}; loaded: {foundryCatalog.Availability.EffectiveRunningModels.Count}.{accelerationDetail}");
        }
        catch (Exception exception)
        {
            llmErrorMessage = exception.Message;
            Operations.Error("Foundry Local catalog load failed.", exception.Message);
        }
        finally
        {
            isCheckingFoundry = false;
        }
    }

    private Task RefreshSelectedProviderAsync()
        => IsOllamaSelected ? CheckOllamaAsync() : CheckFoundryAsync();

    private Task UseSessionLlmSettingsAsync()
    {
        llmErrorMessage = null;

        try
        {
            Workspace.SetLlmSessionSettings(selectedModel, selectedThinkingLevel);
            Operations.Success(
                $"{GetSelectedProviderLabel()} session settings updated.",
                $"{Workspace.SelectedLlmModel} / {FormatThinkingLevel(Workspace.SelectedThinkingLevel)} thinking");
        }
        catch (Exception exception)
        {
            llmErrorMessage = exception.Message;
            Operations.Error("Session LLM settings were not updated.", exception.Message);
            return Task.CompletedTask;
        }

        if (IsOllamaSelected && OllamaOptions.RunCapacityProbeOnModelSelect)
        {
            _ = RunCapacityProbeAsync(Workspace.SelectedLlmModel);
        }

        return Task.CompletedTask;
    }

    private async Task DownloadSelectedModelsAsync()
    {
        if (IsOllamaSelected)
        {
            return;
        }

        var selectedAliases = GetSelectedFoundryDownloadCandidates();
        if (selectedAliases.Count == 0)
        {
            return;
        }

        llmErrorMessage = null;
        isDownloadingFoundryModel = true;

        try
        {
            for (var index = 0; index < selectedAliases.Count; index++)
            {
                var alias = selectedAliases[index];
                downloadingFoundryAlias = alias;
                await Operations.RunAsync(
                    "Downloading Foundry models",
                    $"{alias} ({index + 1}/{selectedAliases.Count})",
                    () => FoundryCatalogClient.DownloadModelAsync(
                        alias,
                        progress => Operations.UpdateCurrent(
                            "Downloading Foundry models",
                            FoundryProgressFormatter.FormatDetail($"{alias} ({index + 1}/{selectedAliases.Count})", progress))));
            }

            await RefreshFoundrySnapshotAsync();
            Operations.Success(
                "Selected Foundry models downloaded.",
                $"Downloaded {selectedAliases.Count} selected model(s) into the local Foundry cache.");
        }
        catch (Exception exception)
        {
            llmErrorMessage = exception.Message;
            Operations.Error("Selected Foundry models could not be downloaded.", exception.Message);
        }
        finally
        {
            isDownloadingFoundryModel = false;
            downloadingFoundryAlias = string.Empty;
        }
    }

    private async Task RegisterFoundryExecutionProvidersAsync()
    {
        if (IsOllamaSelected || !OperatingSystem.IsWindows())
        {
            return;
        }

        llmErrorMessage = null;
        isRegisteringFoundryExecutionProviders = true;

        try
        {
            var providerNames = GetPreferredExecutionProviders();
            var detail = providerNames.Count == 0
                ? "All available providers"
                : string.Join(", ", providerNames);

            await Operations.RunAsync(
                "Registering Windows ML execution providers",
                detail,
                () => FoundryCatalogClient.RegisterExecutionProvidersAsync(
                    providerNames,
                    (providerName, percent) => Operations.UpdateCurrent(
                        "Registering Windows ML execution providers",
                        FoundryProgressFormatter.FormatDetail(providerName, percent))));

            await RefreshFoundrySnapshotAsync();
            Operations.Success(
                "Windows ML execution providers updated.",
                foundryCatalog?.Acceleration.StatusMessage);
        }
        catch (Exception exception)
        {
            llmErrorMessage = exception.Message;
            Operations.Error("Windows ML execution provider registration failed.", exception.Message);
        }
        finally
        {
            isRegisteringFoundryExecutionProviders = false;
        }
    }

    private async Task StartBenchmarkSelectedAsync()
    {
        var models = GetSelectedActionModels();
        if (models.Count == 0)
        {
            return;
        }

        try
        {
            var isFoundryRun = !IsOllamaSelected;
            var selectedDownloadCandidates = isFoundryRun ? GetSelectedFoundryDownloadCandidates().Count : 0;

            Operations.Info(
                $"Benchmarking {models.Count} selected {GetSelectedProviderLabel()} model(s).",
                isFoundryRun && selectedDownloadCandidates > 0
                    ? $"{selectedDownloadCandidates} selected model(s) will be downloaded first."
                    : "This can take a long time.");

            await BenchmarkCoordinator.StartAsync(
                selectedProvider,
                models,
                downloadMissingModels: isFoundryRun,
                removeTooLargeModelsAfterBenchmark: isFoundryRun && removeTooLargeFoundryModelsAfterBenchmark);

            if (isFoundryRun)
            {
                await RefreshFoundrySnapshotAsync();
            }

            var completed = BenchmarkCoordinator.Last;
            if (completed is null)
            {
                return;
            }

            if (completed.IsCancelled)
            {
                Operations.Info("Model benchmark cancelled.", $"Captured {completed.Results.Count} partial result(s) for {FormatProviderLabel(completed.Provider)}.");
            }
            else
            {
                var top = completed.Results.FirstOrDefault();
                Operations.Success(
                    "Model benchmark complete.",
                    top is null ? null : $"Top {FormatProviderLabel(completed.Provider)} model: {top.Model} (overall {top.OverallScore:0.00}).");
            }
        }
        catch (Exception exception)
        {
            Operations.Error("Model benchmark failed to start.", exception.Message);
        }
    }

    private async Task RefreshFoundrySnapshotAsync(CancellationToken cancellationToken = default)
    {
        foundryCatalog = await FoundryCatalogClient.GetSnapshotAsync(cancellationToken);
        Workspace.SetFoundryAvailability(foundryCatalog.Availability);
        selectedModel = Workspace.SelectedLlmModel;
        selectedThinkingLevel = Workspace.SelectedThinkingLevel;
        ReconcileSelectedActionModels();
    }

    private async Task RunCapacityProbeAsync(string model)
    {
        if (string.IsNullOrWhiteSpace(model))
        {
            return;
        }

        try
        {
            var verdict = await CapacityProbe.ProbeAsync(model);
            Workspace.SetCapacityVerdict(verdict);
            await InvokeAsync(StateHasChanged);
            Operations.Info(
                $"Hardware fit for {model}: {verdict.Fit}.",
                verdict.Headline);
        }
        catch (Exception exception)
        {
            Operations.Info(
                $"Could not measure hardware fit for {model}.",
                exception.Message);
        }
    }

