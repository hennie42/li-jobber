        => session.Results.Count(result => result.Notes.Any(static note => note.Contains("could not be removed from the local Foundry cache", StringComparison.OrdinalIgnoreCase)
            || note.Contains("Foundry catalog refresh failed afterward", StringComparison.OrdinalIgnoreCase)));

