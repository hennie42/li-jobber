@page "/diagnostics/session"
@implements IDisposable
@using LiCvWriter.Infrastructure.LinkedIn
@inject OperationStatusService Operations
@inject WorkspaceSession Workspace

<PageTitle>Session Diagnostics</PageTitle>

<section class="page-header">
    <div>
        <div class="eyebrow">Session Diagnostics</div>
        <h1>Inspect live LLM telemetry for the whole session</h1>
        <p>This view is global to the current session. The default workflow UI stays minimal, while deeper telemetry and any thinking preview stay here.</p>
    </div>
</section>

<section class="content-grid">
    <article class="card-panel stack-gap">
        <div class="field-label">Current telemetry</div>
        @if (GetMostRelevantTelemetry() is { } telemetry)
        {
            <div class="status-chip @(telemetry.Completed ? "status-ok" : "status-pending")">
                @(telemetry.Completed ? "Last completed LLM telemetry" : "LLM work is active")
            </div>
            <dl class="key-value-grid compact-grid">
                <dt>Phase</dt>
                <dd>@telemetry.Message</dd>
                <dt>Model</dt>
                <dd>@telemetry.Model</dd>
                <dt>Elapsed</dt>
                <dd>@FormatDuration(telemetry.Elapsed)</dd>
                <dt>Updated</dt>
                <dd>@telemetry.Timestamp.ToString("HH:mm:ss")</dd>
                @if (telemetry.PromptTokens is not null)
                {
                    <dt>Prompt tokens</dt>
                    <dd>@FormatTokenCount(telemetry.PromptTokens)</dd>
                }
                @if (telemetry.CompletionTokens is not null)
                {
                    <dt>Completion tokens</dt>
                    <dd>@FormatTokenCount(telemetry.CompletionTokens)</dd>
                }
                @if (telemetry.HasEstimatedRemaining)
                {
                    <dt>ETA</dt>
                    <dd>@FormatDuration(telemetry.EstimatedRemaining)</dd>
                }
                <dt>Status</dt>
                <dd>@(telemetry.Completed ? "Completed" : "Streaming")</dd>
            </dl>
            @if (!string.IsNullOrWhiteSpace(telemetry.Detail))
            {
                <p class="muted-text">@telemetry.Detail</p>
            }
        }
        else
        {
            <p class="muted-text">No LLM telemetry has been captured in this session yet.</p>
        }
    </article>

    <article class="card-panel stack-gap">
        <div class="field-label">Session context</div>
        <dl class="key-value-grid compact-grid">
            <dt>LLM ready</dt>
            <dd>@(Workspace.IsLlmReady ? "Yes" : "No")</dd>
            <dt>Session model</dt>
            <dd>@(string.IsNullOrWhiteSpace(Workspace.SelectedLlmModel) ? "Not selected" : Workspace.SelectedLlmModel)</dd>
            <dt>Thinking</dt>
            <dd>@FormatThinkingLevel(Workspace.SelectedThinkingLevel)</dd>
            <dt>Active tab</dt>
            <dd>@Workspace.ActiveJobSet.Title</dd>
            <dt>Target role</dt>
            <dd>@(Workspace.JobPosting?.RoleTitle ?? "No target role yet")</dd>
            <dt>Last activity</dt>
            <dd>@Operations.CurrentMessage</dd>
        </dl>
    </article>
</section>

<section class="card-panel stack-gap">
    <h2>LinkedIn import</h2>
    @if (GetLinkedInImportDiagnostics() is { } linkedInImport)
    {
        <div class="status-chip status-ok">Imported from @linkedInImport.SourceDescription</div>
        <p class="muted-text">This surfaces the LinkedIn importer output for the current session, including the imported experience preview, enrichment notes, mapped files, and warnings.</p>

        <div class="content-grid">
            <article class="details-card stack-gap">
                <div class="field-label">Overview</div>
                <dl class="key-value-grid compact-grid">
                    <dt>Imported profile</dt>
                    <dd>@(string.IsNullOrWhiteSpace(linkedInImport.Profile.FullName) ? "Unnamed profile" : linkedInImport.Profile.FullName)</dd>
                    <dt>Inspection root</dt>
                    <dd>@linkedInImport.InspectionRootPath</dd>
                    <dt>Experience</dt>
                    <dd>@linkedInImport.Profile.ExperienceCount</dd>
                    <dt>Education</dt>
                    <dd>@linkedInImport.Profile.EducationCount</dd>
                    <dt>Skills</dt>
                    <dd>@linkedInImport.Profile.SkillCount</dd>
                    <dt>Certifications</dt>
                    <dd>@linkedInImport.Profile.CertificationCount</dd>
                    <dt>Projects</dt>
                    <dd>@linkedInImport.Profile.ProjectCount</dd>
                    <dt>Recommendations</dt>
                    <dd>@linkedInImport.Profile.RecommendationCount</dd>
                    <dt>Enrichment notes</dt>
                    <dd>@linkedInImport.Profile.ManualSignalCount</dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(linkedInImport.Profile.Headline))
                {
                    <p class="muted-text">Headline: @linkedInImport.Profile.Headline</p>
                }

                @if (!string.IsNullOrWhiteSpace(linkedInImport.Profile.Summary))
                {
                    <p class="muted-text">Summary: @linkedInImport.Profile.Summary</p>
                }
            </article>

            <article class="details-card stack-gap">
                <div class="field-label">Mapped files</div>
                @if (linkedInImport.DiscoveredFiles.Count > 0)
                {
                    <ul class="feature-list compact-list">
                        @foreach (var file in linkedInImport.DiscoveredFiles)
                        {
                            <li>@file</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="muted-text">No mapped LinkedIn files were materialized for this import.</p>
                }
            </article>
        </div>

        <details class="details-card" open>
            <summary>Imported experience (@linkedInImport.ExperienceEntries.Count)</summary>
            <div class="stack-gap">
                @if (linkedInImport.ExperienceEntries.Count == 0)
                {
                    <p class="muted-text">No job titles were imported from the LinkedIn DMA member snapshot.</p>
                }
                else
                {
                    @foreach (var experience in linkedInImport.ExperienceEntries)
                    {
                        <div class="details-card stack-gap">
                            <div class="field-label">@experience.DisplayTitle</div>
                            @if (!string.IsNullOrWhiteSpace(experience.Period) || !string.IsNullOrWhiteSpace(experience.Location))
                            {
                                <p class="muted-text">@FormatExperienceMeta(experience)</p>
                            }
                            <ul class="feature-list compact-list">
                                @foreach (var line in experience.DescriptionLines)
                                {
                                    <li>@line</li>
                                }
                            </ul>
                        </div>
                    }
                }
            </div>
        </details>

        <details class="details-card">
            <summary>Enrichment notes (@linkedInImport.ManualSignalEntries.Count)</summary>
            <div class="stack-gap">
                @if (linkedInImport.ManualSignalEntries.Count == 0)
                {
                    <p class="muted-text">No LinkedIn enrichment notes were imported for this session.</p>
                }
                else
                {
                    @foreach (var note in linkedInImport.ManualSignalEntries)
                    {
                        <div class="details-card stack-gap">
                            <div class="field-label">@note.Title</div>
                            @if (note.Lines.Count == 1)
                            {
                                <p class="muted-text">@note.Lines[0]</p>
                            }
                            else
                            {
                                <ul class="feature-list compact-list">
                                    @foreach (var line in note.Lines)
                                    {
                                        <li>@line</li>
                                    }
                                </ul>
                            }
                        </div>
                    }
                }
            </div>
        </details>

        <details class="details-card" @(linkedInImport.Warnings.Count > 0 ? "open" : null)>
            <summary>Warnings (@linkedInImport.Warnings.Count)</summary>
            <div class="stack-gap">
                @if (linkedInImport.Warnings.Count == 0)
                {
                    <p class="muted-text">No LinkedIn import warnings were recorded for this session.</p>
                }
                else
                {
                    <ul class="feature-list compact-list">
                        @foreach (var warning in linkedInImport.Warnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                }
            </div>
        </details>
    }
    else
    {
        <div class="status-chip status-pending">LinkedIn import not loaded</div>
        <p class="muted-text">Load the DMA member snapshot on Start / Setup to surface import diagnostics here.</p>
    }
</section>

@if (GetMostRelevantTelemetry()?.HasThinkingPreview == true)
{
    <section class="card-panel stack-gap">
        <h2>Thinking preview</h2>
        <p class="muted-text">This stays in diagnostics only and is intentionally hidden from the default workflow UI.</p>
        <pre class="response-box">@GetMostRelevantTelemetry()!.ThinkingPreview</pre>
    </section>
}

<section class="card-panel stack-gap">
    <h2>Recent activity</h2>
    <div class="activity-feed">
        @foreach (var entry in Operations.Entries.Take(12))
        {
            <article class="activity-entry activity-@entry.Level">
                <div class="activity-message">@entry.Message</div>
                @if (!string.IsNullOrWhiteSpace(entry.Detail))
                {
                    <div class="activity-detail">@entry.Detail</div>
                }
                <div class="activity-time">@entry.Timestamp.ToString("HH:mm:ss")</div>
            </article>
        }
    </div>
</section>

@code {
    protected override void OnInitialized()
    {
        Operations.Changed += HandleChanged;
        Workspace.Changed += HandleChanged;
    }

    public void Dispose()
    {
        Operations.Changed -= HandleChanged;
        Workspace.Changed -= HandleChanged;
    }

    private LlmOperationTelemetry? GetMostRelevantTelemetry()
        => Operations.CurrentLlmTelemetry ?? Operations.LastCompletedLlmTelemetry;

    private LinkedInImportDiagnosticsSnapshot? GetLinkedInImportDiagnostics()
        => Workspace.ImportResult is null
            ? null
            : LinkedInImportDiagnosticsFormatter.BuildSnapshot(Workspace.ImportResult);

    private static string FormatDuration(TimeSpan? duration)
    {
        if (duration is null)
        {
            return "Pending";
        }

        var value = duration.Value;
        return value.TotalMinutes >= 1
            ? value.ToString(@"m\:ss")
            : value.ToString(@"s\.f\s");
    }

    private static string FormatThinkingLevel(string value)
        => string.IsNullOrWhiteSpace(value)
            ? "Pending"
            : char.ToUpperInvariant(value[0]) + value[1..];

    private static string FormatTokenCount(long? tokens)
        => tokens?.ToString("N0") ?? "Pending";

    private static string FormatExperienceMeta(LinkedInImportExperienceSnapshot experience)
    {
        var segments = new List<string>();

        if (!string.IsNullOrWhiteSpace(experience.Period))
        {
            segments.Add(experience.Period);
        }

        if (!string.IsNullOrWhiteSpace(experience.Location))
        {
            segments.Add(experience.Location);
        }

        return string.Join(" | ", segments);
    }

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);
}