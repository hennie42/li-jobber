@page "/"
@implements IDisposable
@inject WorkspaceSession Workspace

<PageTitle>Start / Overview</PageTitle>

<header class="card-panel setup-header">
    <div class="setup-header-row">
        <div>
            <div class="field-label">Start</div>
            <h2>Workspace overview</h2>
            <p class="muted-text">@GetWorkbenchReadinessMessage()</p>
        </div>
        <div class="button-row">
            <a class="secondary-button" href="/setup/llm">LLM setup</a>
            <a class="secondary-button" href="/setup/linkedin">LinkedIn</a>
            <a class="secondary-button" href="/setup/differentiators">Differentiators</a>
            <a class="primary-button setup-header-cta" href="/workspace/job-workbench">Open Job Workbench →</a>
        </div>
    </div>
    <div class="readiness-chips">
        <span class="status-chip @(Workspace.IsLlmReady ? "status-ok" : "status-pending")">
            @FormatProviderLabel(Workspace.SelectedLlmProvider): @(Workspace.IsLlmReady ? "ready" : "pending")
        </span>
        <span class="status-chip @(Workspace.CandidateProfile is null ? "status-pending" : "status-ok")">
            Profile: @(Workspace.CandidateProfile is null ? "not loaded" : "loaded")
        </span>
        <span class="status-chip @(Workspace.ApplicantDifferentiatorProfile.HasContent ? "status-ok" : "status-pending")">
            Differentiators: @(Workspace.ApplicantDifferentiatorProfile.HasContent ? "saved" : "optional")
        </span>
        <span class="status-chip status-neutral">
            Jobsets: @Workspace.JobSets.Count
        </span>
    </div>
</header>

<section class="content-grid setup-grid">
    <section class="card-panel stack-gap">
        <div class="field-label">LLM</div>
        <h3>Selection and related work</h3>
        <div class="status-chip @(Workspace.IsLlmReady ? "status-ok" : "status-pending")">
            @GetLlmStatusMessage()
        </div>
        <dl class="key-value-grid compact-grid">
            <dt>Provider</dt>
            <dd>@FormatProviderLabel(Workspace.SelectedLlmProvider)</dd>
            <dt>Session model</dt>
            <dd>@(string.IsNullOrWhiteSpace(Workspace.SelectedLlmModel) ? "Pending" : Workspace.SelectedLlmModel)</dd>
            <dt>Thinking</dt>
            <dd>@FormatThinkingLevel(Workspace.SelectedThinkingLevel)</dd>
            <dt>Available models</dt>
            <dd>@GetSelectedAvailabilityModelCount()</dd>
        </dl>
        @if (Workspace.CurrentCapacityVerdict is { } capacityVerdict)
        {
            <div class="status-chip @CapacityChipClass(capacityVerdict.Fit)">
                Hardware fit: @capacityVerdict.Fit — @capacityVerdict.Headline
            </div>
        }
        <div class="button-row">
            <a class="primary-button" href="/setup/llm">Open LLM setup</a>
        </div>
    </section>

    <section class="card-panel stack-gap">
        <div class="field-label">LinkedIn</div>
        <h3>Profile import and review</h3>
        <div class="status-chip @(Workspace.LinkedInAuthorizationStatus.IsAuthorized ? "status-ok" : "status-pending")">
            @Workspace.LinkedInAuthorizationStatus.Message
        </div>
        <dl class="key-value-grid compact-grid">
            <dt>Profile</dt>
            <dd>@(Workspace.CandidateProfile?.Name.FullName ?? "Pending")</dd>
            <dt>Experience</dt>
            <dd>@(Workspace.CandidateProfile?.Experience.Count ?? 0)</dd>
            <dt>Education</dt>
            <dd>@(Workspace.CandidateProfile?.Education.Count ?? 0)</dd>
            <dt>Recommendations</dt>
            <dd>@(Workspace.CandidateProfile?.Recommendations.Count ?? 0)</dd>
        </dl>
        <div class="button-row">
            <a class="primary-button" href="/setup/linkedin">Open LinkedIn page</a>
        </div>
    </section>

    <section class="card-panel stack-gap">
        <div class="field-label">Differentiators</div>
        <h3>Personal positioning</h3>
        <div class="status-chip @(Workspace.ApplicantDifferentiatorProfile.HasContent ? "status-ok" : "status-pending")">
            @(Workspace.ApplicantDifferentiatorProfile.HasContent
                ? "Differentiators stored for this session."
                : "Optional inputs are still empty.")
        </div>
        @if (Workspace.ApplicantDifferentiatorProfile.ToSummaryLines().Take(3).ToArray() is { Length: > 0 } summaryLines)
        {
            <ul class="feature-list compact-list">
                @foreach (var line in summaryLines)
                {
                    <li>@line</li>
                }
            </ul>
        }
        else
        {
            <p class="muted-text">Add notes manually or draft the fields from an Insights Discovery PDF.</p>
        }
        <div class="button-row">
            <a class="primary-button" href="/setup/differentiators">Open differentiators page</a>
        </div>
    </section>
</section>

<section class="card-panel stack-gap">
    <div class="hero-row">
        <div>
            <div class="field-label">Jobs</div>
            <h3>Job workbench status</h3>
            <p class="muted-text">Track every jobset and jump directly to the workbench when you want to edit details or run deeper analysis.</p>
        </div>
        <div class="button-row">
            <a class="primary-button" href="/workspace/job-workbench">Open Job Workbench</a>
        </div>
    </div>

    <div class="readiness-chips">
        <span class="status-chip status-neutral">Total: @Workspace.JobSets.Count</span>
        <span class="status-chip @(GetJobSetCount(JobSetProgressState.Running) > 0 ? "status-pending" : "status-neutral")">Running: @GetJobSetCount(JobSetProgressState.Running)</span>
        <span class="status-chip @(GetJobSetCount(JobSetProgressState.Done) > 0 ? "status-ok" : "status-neutral")">Done: @GetJobSetCount(JobSetProgressState.Done)</span>
        <span class="status-chip @(GetJobSetCount(JobSetProgressState.Failed) > 0 ? "status-warning" : "status-neutral")">Failed: @GetJobSetCount(JobSetProgressState.Failed)</span>
        <span class="status-chip status-neutral">Pending: @GetPendingJobSetCount()</span>
    </div>

    @if (Workspace.JobSets.Count == 0)
    {
        <p class="muted-text">No jobsets are in the workspace yet. Open Job Workbench to add the first one.</p>
    }
    else
    {
        <table class="compact-grid">
            <thead>
                <tr><th>Jobset</th><th>Status</th><th>Fit</th><th>Subtasks</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var jobSet in Workspace.JobSets.OrderBy(job => job.SortOrder))
                {
                    <tr>
                        <td>
                            <strong>@jobSet.Title</strong>
                            <div class="muted-text">@jobSet.OutputFolderName</div>
                        </td>
                        <td>
                            <span class="status-chip @GetProgressChipClass(jobSet.ProgressState)">@jobSet.ProgressState</span>
                            @if (!string.IsNullOrWhiteSpace(jobSet.ProgressDetail))
                            {
                                <div class="muted-text">@jobSet.ProgressDetail</div>
                            }
                        </td>
                        <td>@(jobSet.JobFitAssessment.HasSignals ? $"{jobSet.JobFitAssessment.OverallScore}/100" : "Pending")</td>
                        <td>
                            <div class="subtask-indicators">
                                @foreach (var subtask in Subtasks)
                                {
                                    var status = jobSet.GetSubtaskStatus(subtask);
                                    <span class="subtask-chip subtask-@GetSubtaskStatusClass(status)" title="@FormatSubtaskLabel(subtask): @status">@FormatSubtaskLabel(subtask)</span>
                                }
                            </div>
                        </td>
                        <td><a class="link-button" href="@($"/workspace/job-workbench/{jobSet.Id}")">Open</a></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private static readonly JobSetSubtask[] Subtasks =
    [
        JobSetSubtask.JobContext,
        JobSetSubtask.FitReview,
        JobSetSubtask.TechnologyGap,
        JobSetSubtask.DraftGeneration
    ];

    protected override void OnInitialized()
    {
        Workspace.Changed += HandleChanged;
    }

    public void Dispose()
    {
        Workspace.Changed -= HandleChanged;
    }

    private static string FormatProviderLabel(LlmProviderKind provider)
        => provider switch
        {
            LlmProviderKind.Foundry => "Microsoft Foundry Local",
            _ => "Ollama"
        };

    private string GetLlmStatusMessage()
    {
        if (Workspace.IsLlmReady)
        {
            return $"Ready: {FormatProviderLabel(Workspace.SelectedLlmProvider)} using {Workspace.SelectedLlmModel}.";
        }

        var availability = GetSelectedAvailability();
        if (availability is null)
        {
            return $"{FormatProviderLabel(Workspace.SelectedLlmProvider)} catalog is still pending.";
        }

        return availability.AvailableModels.Count == 0
            ? $"{FormatProviderLabel(Workspace.SelectedLlmProvider)} has no ready models yet."
            : "Choose and save the session model to continue.";
    }

    private int GetSelectedAvailabilityModelCount()
        => GetSelectedAvailability()?.AvailableModels.Count ?? 0;

    private LlmModelAvailability? GetSelectedAvailability()
        => Workspace.SelectedLlmProvider == LlmProviderKind.Foundry
            ? Workspace.FoundryAvailability
            : Workspace.OllamaAvailability;

    private string GetWorkbenchReadinessMessage()
    {
        if (!Workspace.IsLlmReady)
        {
            return Workspace.SelectedLlmProvider == LlmProviderKind.Ollama
                ? "Complete Ollama setup first."
                : "Load the Foundry catalog, choose a cached model, and apply it to the session first.";
        }

        if (Workspace.CandidateProfile is null)
        {
            return "Load the DMA member snapshot next.";
        }

        if (Workspace.JobSets.All(jobSet => jobSet.JobPosting is null))
        {
            return "The setup foundation is ready. Add or select a jobset next.";
        }

        return "The session, profile, and job context are ready for deeper work.";
    }

    private static string FormatThinkingLevel(string value)
        => string.IsNullOrWhiteSpace(value)
            ? "Pending"
            : char.ToUpperInvariant(value[0]) + value[1..];

    private int GetJobSetCount(JobSetProgressState state)
        => Workspace.JobSets.Count(jobSet => jobSet.ProgressState == state);

    private int GetPendingJobSetCount()
        => Workspace.JobSets.Count(jobSet => jobSet.ProgressState == JobSetProgressState.NotStarted);

    private static string CapacityChipClass(OllamaCapacityFit fit) => fit switch
    {
        OllamaCapacityFit.Comfortable => "status-ok",
        OllamaCapacityFit.Usable => "status-ok",
        OllamaCapacityFit.PartialOffload => "status-pending",
        OllamaCapacityFit.CpuOnly => "status-pending",
        OllamaCapacityFit.TooLargeForInteractive => "status-error",
        _ => "status-pending"
    };

    private static string GetProgressChipClass(JobSetProgressState state) => state switch
    {
        JobSetProgressState.Done => "status-ok",
        JobSetProgressState.Running => "status-pending",
        JobSetProgressState.Failed => "status-warning",
        _ => "status-neutral"
    };

    private static string GetSubtaskStatusClass(JobSetSubtaskStatus status) => status switch
    {
        JobSetSubtaskStatus.Done => "done",
        JobSetSubtaskStatus.Running => "running",
        _ => "not-started"
    };

    private static string FormatSubtaskLabel(JobSetSubtask subtask) => subtask switch
    {
        JobSetSubtask.JobContext => "Context",
        JobSetSubtask.FitReview => "Fit",
        JobSetSubtask.TechnologyGap => "Gap",
        JobSetSubtask.DraftGeneration => "Drafts",
        _ => subtask.ToString()
    };

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);
}
