@page "/workspace/import-profile"
@inject NavigationManager Navigation

<PageTitle>Redirecting</PageTitle>

<section class="card-panel stack-gap">
    <div class="field-label">Redirect</div>
    <h1>Opening Start / Setup</h1>
    <p class="muted-text">The profile import flow now lives on the Start / Setup page.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.NavigateTo("/", replace: true);
        }
    }
}

