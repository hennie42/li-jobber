    private bool TryEnsureResearchReadiness()
    {
        if (!Workspace.IsLlmReady)
        {
            errorMessage = "Complete Start / Setup first: check Ollama, choose a session model, and choose a thinking level before parsing the job or company context.";
            return false;
        }

        return true;
    }

    private bool TryGetJobUri(out Uri jobUri)
    {
        if (!Uri.TryCreate(jobUrl, UriKind.Absolute, out jobUri!))
        {
            errorMessage = "Please enter a valid absolute job URL.";
            return false;
        }

        return true;
    }

    private bool TryGetCompanyContextUris(out Uri[] companyContextUris)
    {
        companyContextUris = companyUrls
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(value => Uri.TryCreate(value, UriKind.Absolute, out var uri) ? uri : null)
            .Where(static uri => uri is not null)
            .Cast<Uri>()
            .ToArray();

        if (companyContextUris.Length == 0)
        {
            errorMessage = "Add at least one absolute company URL.";
            return false;
        }

        return true;
    }

    private async Task<bool> ExecuteJobAnalysisAsync(
        Uri uri,
        bool manageCurrentOperation = true,
        bool markLlmWorkStarted = true,
        bool emitSuccess = true,
        string? userErrorPrefix = null)
    {
        try
        {
            if (manageCurrentOperation)
            {
                currentOperation = BusyOperation.AnalyzeJob;
            }

            if (markLlmWorkStarted)
            {
                Workspace.MarkLlmWorkStarted();
            }

            Workspace.MarkJobSetRunning(JobSetId!, "Job analysis is running for this tab.");
            analysis = await Operations.RunAsync(
                AnalyzeJobMessage,
                $"{uri} via {Workspace.SelectedLlmModel}",
                () => JobResearchService.AnalyzeAsync(uri, Workspace.SelectedLlmModel, Workspace.SelectedThinkingLevel, ReportLlmProgress));

            Workspace.SetJobSetJobPosting(JobSetId!, analysis);
            SyncFromWorkspace();

            if (emitSuccess)
            {
                Operations.Success("Job analysis updated.", "The job tab now has the latest target role context. Fit review and generation are still idle until you run them.");
            }

            return true;
        }
        catch (Exception exception)
        {
            errorMessage = string.IsNullOrWhiteSpace(userErrorPrefix)
                ? exception.Message
                : $"{userErrorPrefix}: {exception.Message}";
            Workspace.MarkJobSetFailed(JobSetId!, "Job analysis failed for this tab.");
            Operations.Error("Job analysis failed.", exception.Message);
            return false;
        }
        finally
        {
            if (manageCurrentOperation)
            {
                currentOperation = BusyOperation.None;
            }
        }
    }

