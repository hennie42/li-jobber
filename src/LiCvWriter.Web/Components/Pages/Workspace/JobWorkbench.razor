    [JSInvokable]
    public async Task HandleLlmOperationEvent(string eventType, string payload)
    {
        var operationEvent = JsonSerializer.Deserialize<LlmOperationEvent>(payload);
        if (operationEvent is null || !string.Equals(operationEvent.Snapshot.OperationId, activeStreamOperationId, StringComparison.Ordinal))
        {
            return;
        }

        activeStreamSnapshot = operationEvent.Snapshot;

        if (!string.Equals(activeStreamSnapshot.JobSetId, JobSetId!, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        if (activeStreamSnapshot.IsTerminal)
        {
            currentOperation = BusyOperation.None;
            StopOperationTimer();
            SyncFromWorkspace();

            if (activeStreamSnapshot.Kind is "analyze-job-context" or "refresh-all" && activeStreamSnapshot.Status == "completed")
            {
                SetAdditionalInstructions(BuildResearchInstructions());
            }

            if (activeStreamSnapshot.Status == "completed")
            {
                await RefreshOllamaAvailabilitySilentlyAsync();
            }

            if (activeStreamSnapshot.Status == "failed")
            {
                errorMessage = activeStreamSnapshot.Error ?? activeStreamSnapshot.Detail;
            }

            activeOperationCompletionSource?.TrySetResult(activeStreamSnapshot);

            await DisposeActiveStreamAsync(clearSnapshot: false);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task StartStreamedOperationAsync<TRequest>(string relativePath, TRequest request)
    {
        await DisposeActiveStreamAsync();

        var client = HttpClientFactory.CreateClient();
        using var response = await client.PostAsJsonAsync(Navigation.ToAbsoluteUri(relativePath), request);

        if (!response.IsSuccessStatusCode)
        {
            var error = await response.Content.ReadAsStringAsync();
            throw new InvalidOperationException(string.IsNullOrWhiteSpace(error)
                ? $"Operation start failed with status {(int)response.StatusCode}."
                : error.Trim().Trim('"'));
        }

        var startResult = await response.Content.ReadFromJsonAsync<LlmOperationStartResult>()
            ?? throw new InvalidOperationException("The operation start response was empty.");

        activeStreamOperationId = startResult.OperationId;
        activeStreamSnapshot = null;
        activeOperationCompletionSource = new TaskCompletionSource<LlmOperationSnapshot>(TaskCreationOptions.RunContinuationsAsynchronously);
        streamCallbackReference ??= DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync(
            "liCvWriterLlmStream.subscribe",
            startResult.OperationId,
            Navigation.ToAbsoluteUri(startResult.EventsPath).ToString(),
            streamCallbackReference);
    }

    private async Task DisposeActiveStreamAsync(bool clearSnapshot = true)
    {
        if (!string.IsNullOrWhiteSpace(activeStreamOperationId))
        {
            try
            {
                await JS.InvokeVoidAsync("liCvWriterLlmStream.dispose", activeStreamOperationId);
            }
            catch (JSDisconnectedException)
            {
                // Ignore disconnects during teardown.
            }
        }

        activeStreamOperationId = null;

        if (clearSnapshot)
        {
            activeStreamSnapshot = null;
        }

        activeOperationCompletionSource?.TrySetCanceled();
        activeOperationCompletionSource = null;
    }

    private async Task<LlmOperationSnapshot> StartStreamedOperationAndWaitAsync<TRequest>(string relativePath, TRequest request)
    {
        await StartStreamedOperationAsync(relativePath, request);
        var completionSource = activeOperationCompletionSource
            ?? throw new InvalidOperationException("The operation stream did not initialize correctly.");
        return await completionSource.Task;
    }

    private void ClearRetainedStreamState()
    {
        activeStreamOperationId = null;
        activeStreamSnapshot = null;
        activeOperationCompletionSource = null;
    }

    private async Task RunAllRefreshThenDraftsAsync()
    {
        errorMessage = null;
        batchSkippedJobSetMessages.Clear();

        if (!Workspace.IsLlmReady)
        {
            errorMessage = "Complete Start / Setup first: check Ollama, choose a session model, and choose a thinking level.";
            return;
        }

        if (Workspace.CandidateProfile is null)
        {
            errorMessage = "Load a LinkedIn profile before running all jobsets.";
            return;
        }

        var kinds = GetSelectedDocumentKinds();
        if (kinds.Count == 0)
        {
            errorMessage = "Select at least one document type before running all jobsets.";
            return;
        }

        var readyJobSets = Workspace.JobSets
            .OrderBy(jobSet => jobSet.SortOrder)
            .Where(CanRunBatchDraftGeneration)
            .ToArray();
        var skippedJobSets = Workspace.JobSets
            .OrderBy(jobSet => jobSet.SortOrder)
            .Where(jobSet => !CanRunBatchDraftGeneration(jobSet))
            .Select(jobSet => $"Skipped {jobSet.Title}: {GetBatchReadinessMessage(jobSet)}")
            .ToArray();

        foreach (var skippedMessage in skippedJobSets)
        {
            batchSkippedJobSetMessages.Add(skippedMessage);
        }

        if (readyJobSets.Length == 0)
        {
            errorMessage = skippedJobSets.Length == 0
                ? "No jobsets are ready to run."
                : "No jobsets are ready to run. See the skipped jobsets listed above.";
            return;
        }

        isBatchRunning = true;
        batchCompletedCount = 0;
        batchTotalCount = readyJobSets.Length;
        StartOperationTimer();

        try
        {
            foreach (var jobSet in readyJobSets)
            {
                batchCurrentJobSetTitle = jobSet.Title;

                currentOperation = BusyOperation.RefreshAll;
                var refreshSnapshot = await StartStreamedOperationAndWaitAsync(
                    "/api/llm/operations/refresh-all",
                    new StartRefreshAllOperationRequest(jobSet.Id));

                if (refreshSnapshot.Status != "completed")
                {
                    throw new InvalidOperationException(refreshSnapshot.Error ?? refreshSnapshot.Detail ?? $"Refresh-all failed for {jobSet.Title}.");
                }

                currentOperation = BusyOperation.GenerateDrafts;
                Workspace.ClearJobSetGeneratedArtifacts(jobSet.Id);

                var draftSnapshot = await StartStreamedOperationAndWaitAsync(
                    "/api/llm/operations/generate-drafts",
                    new StartDraftGenerationOperationRequest(jobSet.Id, kinds.Select(static kind => kind.ToString()).ToArray()));

                if (draftSnapshot.Status != "completed")
                {
                    throw new InvalidOperationException(draftSnapshot.Error ?? draftSnapshot.Detail ?? $"Draft generation failed for {jobSet.Title}.");
                }

                batchCompletedCount++;
            }

            Operations.Success(
                "Start all completed.",
                skippedJobSets.Length == 0
                    ? $"Refreshed and generated drafts for {readyJobSets.Length} jobset(s)."
                    : $"Refreshed and generated drafts for {readyJobSets.Length} jobset(s). Skipped {skippedJobSets.Length} jobset(s).",
                null);
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isBatchRunning = false;
            batchCurrentJobSetTitle = null;
            currentOperation = BusyOperation.None;
            StopOperationTimer();
        }
    }

