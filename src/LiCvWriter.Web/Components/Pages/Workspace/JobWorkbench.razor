    private bool CanRunAnyBatchDraftGeneration()
        => Workspace.IsLlmReady
            && Workspace.CandidateProfile is not null
            && Workspace.JobSets.Any(CanRunBatchDraftGeneration);

    private bool CanRunBatchDraftGeneration(JobSetSessionState jobSet)
        => string.IsNullOrWhiteSpace(GetBatchReadinessMessage(jobSet));

    private string GetBatchReadinessMessage(JobSetSessionState jobSet)
    {
        if (!Workspace.IsLlmReady)
        {
            return "the session LLM is not ready";
        }

        if (Workspace.CandidateProfile is null)
        {
            return "no LinkedIn profile is loaded";
        }

        if (jobSet.JobPosting is null)
        {
            return "job context has not been analyzed";
        }

        return string.Empty;
    }

    private string GetBatchActionLabel()
        => batchTotalCount == 0
            ? "Run all job sets"
            : $"Batch {Math.Min(batchCompletedCount + (isBusy ? 1 : 0), batchTotalCount)} of {batchTotalCount}";

    private string GetCurrentTaskStatusMessage()
    {
        if (isBatchRunning)
        {
            return batchCurrentJobSetTitle is null
                ? $"Batch: {batchCompletedCount} of {batchTotalCount}"
                : $"Batch: {Math.Min(batchCompletedCount + (isBusy ? 1 : 0), batchTotalCount)} of {batchTotalCount} ({batchCurrentJobSetTitle})";
        }

        if (activeStreamSnapshot is { IsTerminal: false } snapshot
            && string.Equals(snapshot.JobSetId, JobSetId!, StringComparison.OrdinalIgnoreCase))
        {
            return $"Running: {snapshot.Message}";
        }

        if (Operations.IsBusy)
        {
            return $"Running: {Operations.CurrentMessage}";
        }

        return $"Status: {GetActiveTabStatusMessage()}";
    }

    private string? GetCurrentTaskStatusDetail()
    {
        if (isBatchRunning)
        {
            return batchCurrentJobSetTitle is null
                ? "Sequential batch generation is preparing the next job tab."
                : $"Current job tab: {batchCurrentJobSetTitle}. {GetActiveTabStatusMessage()}";
        }

        if (activeStreamSnapshot is { IsTerminal: false } snapshot
            && string.Equals(snapshot.JobSetId, JobSetId!, StringComparison.OrdinalIgnoreCase))
        {
            return snapshot.Detail;
        }

        return Operations.IsBusy ? Operations.CurrentDetail : null;
    }

    private string GetCurrentTaskStatusClass()
    {
        if (isBatchRunning || isBusy)
        {
            return "status-pending";
        }

        return CurrentJobSet.ProgressState switch
        {
            JobSetProgressState.Done => "status-ok",
            JobSetProgressState.Failed => "status-warning",
            _ => "status-pending"
        };
    }

    private static string FormatSourceContext(JobRequirementAssessment requirement)
    {
        var segments = new List<string>();

        if (!string.IsNullOrWhiteSpace(requirement.SourceLabel))
        {
            segments.Add(requirement.SourceLabel);
        }

        if (requirement.SourceConfidence is not null)
        {
            segments.Add($"{requirement.SourceConfidence}% confidence");
        }

        return segments.Count == 0 ? "Source-backed extraction" : string.Join(" · ", segments);
    }

    private static string FormatDuration(TimeSpan? duration)
    {
        if (duration is null)
        {
            return "unknown time";
        }

        var value = duration.Value;
        return value.TotalMinutes >= 1
            ? value.ToString(@"m\:ss")
            : value.ToString(@"s\.f\s");
    }

    private static string FormatTokenSummary(GeneratedDocument document)
    {
        if (document.PromptTokens is null && document.CompletionTokens is null)
        {
            return string.Empty;
        }

        return $" ({document.PromptTokens ?? 0} prompt / {document.CompletionTokens ?? 0} completion tokens)";
    }

    private static string FormatTokenCount(long? tokens)
        => tokens?.ToString("N0") ?? "Pending";

    private LlmOperationSnapshot? GetActiveDraftStreamSnapshot()
        => activeStreamSnapshot is { Kind: "generate-drafts" } snapshot
            && string.Equals(snapshot.JobSetId, JobSetId!, StringComparison.OrdinalIgnoreCase)
            ? snapshot
            : null;

    private LlmOperationTelemetry? GetCurrentLlmTelemetry()
        => IsWorkbenchTelemetryActive() ? Operations.ActiveLlmTelemetry : null;

    private bool IsWorkbenchTelemetryActive()
    {
        var telemetryMessage = Operations.ActiveLlmTelemetry?.Message;
        if (string.IsNullOrWhiteSpace(telemetryMessage))
        {
            return false;
        }

        return IsWorkbenchTelemetryMessage(telemetryMessage);
    }

    private static bool IsWorkbenchTelemetryMessage(string telemetryMessage)
        => string.Equals(telemetryMessage, ParseJobTelemetryMessage, StringComparison.Ordinal)
            || string.Equals(telemetryMessage, ParseCompanyTelemetryMessage, StringComparison.Ordinal)
            || string.Equals(telemetryMessage, EnhanceFitReviewTelemetryMessage, StringComparison.Ordinal)
            || string.Equals(telemetryMessage, RefreshTechnologyGapMessage, StringComparison.Ordinal)
            || telemetryMessage.StartsWith(GenerateDraftTelemetryPrefix, StringComparison.Ordinal);

    private bool IsCurrentWorkbenchOperation(string message)
        => Operations.IsBusy && string.Equals(Operations.CurrentMessage, message, StringComparison.Ordinal);

    private bool IsActiveTelemetryMessage(string message)
        => string.Equals(Operations.ActiveLlmTelemetry?.Message, message, StringComparison.Ordinal);

    private bool HasActiveTelemetryPrefix(string prefix)
        => Operations.ActiveLlmTelemetry?.Message.StartsWith(prefix, StringComparison.Ordinal) == true;

