    private async Task TryRefreshFitReviewAsync(bool throwOnMissingReadiness = false)
    {
        if (!CanRunFitReview)
        {
            if (throwOnMissingReadiness)
            {
                throw new InvalidOperationException("Load a profile and analyze a target job before running the fit review.");
            }

            return;
        }

        try
        {
            Workspace.MarkJobSetRunning(JobSetId!, "Fit review is running for this tab.");
            var refreshed = await Operations.RunAsync(
                RefreshFitReviewMessage,
                CurrentJobSet.Title,
                () => Task.FromResult(JobFitWorkspaceRefreshService.RefreshJobSet(JobSetId!)));

            if (!refreshed)
            {
                if (throwOnMissingReadiness)
                {
                    throw new InvalidOperationException("Load a profile and analyze a target job before running the fit review.");
                }

                return;
            }

            if (CurrentJobSet.JobFitAssessment.Requirements.Any(static r => r.Match != JobRequirementMatch.Strong))
            {
                Workspace.MarkLlmWorkStarted();
                Workspace.MarkJobSetRunning(JobSetId!, "Enhancing fit review with LLM semantic matching.");
                var enhanced = await FitEnhancementService.EnhanceAsync(
                    CurrentJobSet.JobFitAssessment,
                    Workspace.CandidateProfile!,
                    CurrentJobSet.JobPosting!,
                    CurrentJobSet.CompanyProfile,
                    Workspace.SelectedLlmModel,
                    Workspace.SelectedThinkingLevel,
                    ReportLlmProgress,
                    default);

                Workspace.SetJobSetJobFitAssessment(JobSetId!, enhanced);
                JobFitWorkspaceRefreshService.RefreshJobSetEvidence(JobSetId!);

                if (enhanced.IsLlmEnhanced)
                {
                    var upgradedCount = enhanced.Requirements.Count(static r => r.IsLlmEnhanced);
                    Operations.Info($"LLM enhanced {upgradedCount} requirement(s).", "Semantic evidence matching found additional supporting evidence.");
                }
                else
                {
                    Operations.Info("LLM found no additional evidence.", "The semantic evidence pass did not identify upgrades beyond keyword matching.");
                }
            }

            Workspace.ResetJobSetProgress(JobSetId!, "Fit review updated for this job tab. Markdown generation not started for this tab.");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Workspace.MarkJobSetFailed(JobSetId!, "Fit review failed for this tab.");
            Operations.Error("Fit review failed.", exception.Message);
        }
    }

    private async Task TryRefreshTechnologyGapAsync(bool throwOnMissingReadiness = false)
    {
        if (!CanRunTechnologyGapCheck)
        {
            if (throwOnMissingReadiness)
            {
                throw new InvalidOperationException("Load a profile and complete Start / Setup before running the technology gap check.");
            }

            return;
        }

        try
        {
            Workspace.MarkLlmWorkStarted();
            Workspace.MarkJobSetRunning(JobSetId!, "Technology gap analysis is running for this tab.");
            var assessment = await Operations.RunAsync(
                RefreshTechnologyGapMessage,
                CurrentJobSet.Title,
                () => GapAnalysisService.AnalyzeAsync(
                    Workspace.CandidateProfile!,
                    CurrentJobSet.JobPosting!,
                    CurrentJobSet.CompanyProfile,
                    Workspace.SelectedLlmModel,
                    Workspace.SelectedThinkingLevel,
                    ReportLlmProgress));

            Workspace.SetJobSetTechnologyGapAssessment(JobSetId!, assessment);
            Workspace.ResetJobSetProgress(JobSetId!, "Technology gap analysis completed. Markdown generation not started for this tab.");
            await RefreshOllamaAvailabilitySilentlyAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Workspace.MarkJobSetFailed(JobSetId!, "Technology gap analysis failed for this tab.");
            Operations.Error("Technology gap analysis failed.", exception.Message);
        }
    }

    private Task HandleOutputLanguageChanged(ChangeEventArgs args)
    {
        if (args.Value is null)
        {
            return Task.CompletedTask;
        }

        if (Enum.TryParse<OutputLanguage>(args.Value.ToString(), ignoreCase: true, out var outputLanguage))
        {
            Workspace.SetJobSetOutputLanguage(JobSetId!, outputLanguage);
        }

        return Task.CompletedTask;
    }

    private Task HandleInputLanguageChanged(ChangeEventArgs args)
    {
        if (args.Value is null || string.IsNullOrWhiteSpace(JobSetId))
        {
            return Task.CompletedTask;
        }

        if (Enum.TryParse<JobSetSourceLanguage>(args.Value.ToString(), ignoreCase: true, out var inputLanguage))
        {
            Workspace.SetJobSetInputLanguage(JobSetId, inputLanguage);
            ClearRetainedStreamState();
            SyncFromWorkspace();
        }

        return Task.CompletedTask;
    }

    private async Task DeleteThisJobSetAsync()
    {
        if (string.IsNullOrWhiteSpace(JobSetId))
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete jobset \"{CurrentJobSet.Title}\"? This cannot be undone.");
        if (!confirmed)
        {
            return;
        }

        try
        {
            Workspace.DeleteJobSet(JobSetId);
            errorMessage = null;
            ClearRetainedStreamState();
            SyncFromWorkspace();
            Navigation.NavigateTo("/workspace/job-workbench");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private Task HandleEvidenceSelectionChanged(string evidenceId, ChangeEventArgs args)
    {
        var isSelected = args.Value is bool value && value;
        Workspace.SetJobSetEvidenceSelected(JobSetId!, evidenceId, isSelected);
        return Task.CompletedTask;
    }

    private Task ClearEvidenceSelectionsAsync()
    {
        Workspace.ClearJobSetEvidenceSelections(JobSetId!);
        Operations.Info("Evidence selections cleared.", "The next generation pass will use either refreshed ranking defaults or whatever you select next.");
        return Task.CompletedTask;
    }

    private Task SelectAllEvidenceAsync()
    {
        Workspace.SelectAllJobSetEvidence(JobSetId!);
        Operations.Info("All evidence selected.", "Every ranked evidence item is now selected for this tab.");
        return Task.CompletedTask;
    }

    private void ReportLlmProgress(LlmProgressUpdate update)
    {
        Operations.UpdateCurrent(update);
        Workspace.MarkJobSetRunning(JobSetId!, update.Detail ?? update.Message);
    }

    private async Task RefreshOllamaAvailabilitySilentlyAsync()
    {
        try
        {
            Workspace.SetOllamaAvailability(await LlmClient.VerifyModelAvailabilityAsync());
        }
        catch
        {
            // Preserve the last known status if the quick refresh fails.
        }
    }

    private string GetGenerationReadinessMessage()
    {
        if (!Workspace.IsLlmReady)
        {
            return "Complete Start / Setup before generating drafts.";
        }

        if (Workspace.CandidateProfile is null)
        {
            return "Load a LinkedIn profile before generating drafts.";
        }

        if (CurrentJobSet.JobPosting is null)
        {
            return "Analyze a target job before generating drafts.";
        }

        return "Profile, target role, and the session LLM are ready. Fit review and technology gap stay idle until you run them or generate drafts.";
    }

    private string GetActiveTabStatusMessage()
        => CurrentJobSet.ProgressState switch
        {
            JobSetProgressState.Done => "This job tab has completed markdown generation.",
            JobSetProgressState.Running => CurrentJobSet.ProgressDetail,
            JobSetProgressState.Failed => CurrentJobSet.ProgressDetail,
            _ => CurrentJobSet.ProgressDetail
        };

    private List<DocumentKind> GetSelectedDocumentKinds()
    {
        var kinds = new List<DocumentKind>();

        if (generateCv)
        {
            kinds.Add(DocumentKind.Cv);
        }

        if (generateCoverLetter)
        {
            kinds.Add(DocumentKind.CoverLetter);
        }

        if (generateSummary)
        {
            kinds.Add(DocumentKind.ProfileSummary);
        }

        if (generateInterviewNotes)
        {
            kinds.Add(DocumentKind.InterviewNotes);
        }

        return kinds;
