@page "/workspace/job-workbench"
@implements IDisposable
@using LiCvWriter.Application.Models
@inject ILlmClient LlmClient
@inject JobFitWorkspaceRefreshService JobFitWorkspaceRefreshService
@inject IJobResearchService JobResearchService
@inject IDraftGenerationService DraftGenerationService
@inject LlmTechnologyGapAnalysisService GapAnalysisService
@inject OperationStatusService Operations
@inject WorkspaceSession Workspace

<PageTitle>Job Workbench</PageTitle>

<section class="page-header">
    <div>
        <div class="eyebrow">Job Workbench</div>
        <h2>Job workbench</h2>
        <p>Each tab holds a target role with its own research, fit review, and drafts.</p>
    </div>
</section>

<section class="card-panel stack-gap">
    <div class="field-label">Job tabs</div>
    <div class="button-row">
        @foreach (var jobSet in Workspace.JobSets.OrderBy(jobSet => jobSet.SortOrder))
        {
            <button type="button"
                    class="@(jobSet.Id == Workspace.ActiveJobSetId ? "primary-button" : "secondary-button")"
                    title="@jobSet.ProgressDetail"
                    @onclick="() => SelectJobSet(jobSet.Id)">
                <span class="job-set-button-label">
                    <span class="@GetProgressIndicatorClass(jobSet.ProgressState)" aria-hidden="true"></span>
                    <span>@jobSet.Title (@FormatInputMode(jobSet.InputMode))</span>
                </span>
            </button>
        }

        <button type="button" class="secondary-button" @onclick="() => AddJobSet(JobSetInputMode.LinkToUrls)">Add job tab (URLs)</button>
        <button type="button" class="secondary-button" @onclick="() => AddJobSet(JobSetInputMode.PasteText)">Add job tab (paste text)</button>
        <button type="button" class="secondary-button" @onclick="DeleteActiveJobSet" disabled="@(isBusy || Workspace.JobSets.Count <= 1)">Delete active job tab</button>
    </div>
    @if (Workspace.JobSets.Count == 1)
    {
        <p class="muted-text">At least one job tab must remain in the workspace.</p>
    }
    <div class="status-chip @(Workspace.ActiveJobSet.ProgressState == JobSetProgressState.Done ? "status-ok" : "status-pending")">
        @GetActiveTabStatusMessage()
    </div>
    <div class="job-tabs-meta">
        @Workspace.ActiveJobSet.OutputFolderName
        <span class="meta-sep">&middot;</span>
        @FormatInputMode(Workspace.ActiveJobSet.InputMode)
        <span class="meta-sep">&middot;</span>
        @Workspace.ActiveJobSet.OutputLanguage
        @if (Workspace.IsLlmReady)
        {
            <span class="meta-sep">&middot;</span>
            @Workspace.SelectedLlmModel
        }
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <section class="card-panel">
        <div class="message error">@errorMessage</div>
    </section>
}

<details class="card-panel stack-gap" open>
    <summary><h2>Research</h2></summary>

    @if (isResearching && operationStartedAt is not null)
    {
        <div class="status-chip status-pending">Running @GetOperationElapsed()</div>
    }

    @if (Workspace.ActiveJobSet.InputMode == JobSetInputMode.LinkToUrls)
        {
            <label class="field-label" for="jobUrl">Job URL</label>
            <input id="jobUrl" class="text-input" @bind="jobUrl" @bind:event="oninput" @bind:after="PersistJobSetInputs" />

            <label class="field-label" for="companyUrls">Company context URLs</label>
            <textarea id="companyUrls" class="prompt-box compact-prompt" @bind="companyUrls" @bind:event="oninput" @bind:after="PersistJobSetInputs"></textarea>
        }
        else
        {
            <label class="field-label" for="jobPostingText">Job posting text</label>
            <textarea id="jobPostingText" class="prompt-box" rows="10" @bind="jobPostingText" @bind:event="oninput" @bind:after="PersistJobSetInputs" placeholder="Paste the full job posting text here..."></textarea>

            <label class="field-label" for="companyContextText">Company context text (optional)</label>
            <textarea id="companyContextText" class="prompt-box" rows="8" @bind="companyContextText" @bind:event="oninput" @bind:after="PersistJobSetInputs" placeholder="Paste company information here, or leave empty to skip company context..."></textarea>
        }
        <div class="button-row">
            <button class="primary-button" @onclick="AnalyzeAndBuildContextAsync" disabled="@(isBusy || !Workspace.IsLlmReady)">@(isResearching ? $"Running {GetOperationElapsed()}" : "Analyze job and build company context")</button>
        </div>
        <p class="muted-text">@GetResearchHelpText()</p>

        @if (analysis is not null)
        {
            <details class="details-card" open>
                <summary>Job snapshot</summary>
                <div class="stack-gap">
                    <div>
                        <strong>@analysis.RoleTitle</strong>
                        <p class="muted-text">@analysis.CompanyName</p>
                    </div>
                    <p>@analysis.Summary</p>

                    @if (analysis.MustHaveThemes.Count > 0)
                    {
                        <div>
                            <div class="field-label">Must have themes</div>
                            <ul class="feature-list compact-list">
                                @foreach (var theme in analysis.MustHaveThemes)
                                {
                                    <li>@theme</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (analysis.NiceToHaveThemes.Count > 0)
                    {
                        <div>
                            <div class="field-label">Nice-to-have themes</div>
                            <ul class="feature-list compact-list">
                                @foreach (var theme in analysis.NiceToHaveThemes)
                                {
                                    <li>@theme</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (analysis.CulturalSignals.Count > 0)
                    {
                        <div>
                            <div class="field-label">Culture signals</div>
                            <ul class="feature-list compact-list">
                                @foreach (var signal in analysis.CulturalSignals)
                                {
                                    <li>@signal</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </details>
        }

        @if (companyProfile is not null)
        {
            <details class="details-card">
                <summary>Company context</summary>
                <div class="stack-gap">
                    <p>@companyProfile.Summary</p>
                    @if (companyProfile.SourceUrls.Count > 0)
                    {
                        <p class="muted-text">Built from @companyProfile.SourceUrls.Count source URLs.</p>
                    }
                    else
                    {
                        <p class="muted-text">Built from pasted text.</p>
                    }

                    @if (companyProfile.GuidingPrinciples.Count > 0)
                    {
                        <div>
                            <div class="field-label">Guiding principles</div>
                            <ul class="feature-list compact-list">
                                @foreach (var principle in companyProfile.GuidingPrinciples)
                                {
                                    <li>@principle</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (companyProfile.Differentiators.Count > 0)
                    {
                        <div>
                            <div class="field-label">Differentiators</div>
                            <ul class="feature-list compact-list">
                                @foreach (var differentiator in companyProfile.Differentiators)
                                {
                                    <li>@differentiator</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </details>
        }
    </details>

@if (Workspace.JobFitAssessment.HasSignals)
{
    <details class="card-panel stack-gap" open>
        <summary>
            <div class="fit-header">
                <div>
                    <h2>Fit review</h2>
                </div>
                <div class="status-chip @GetRecommendationStatusClass(Workspace.JobFitAssessment.Recommendation)">
                    @FormatRecommendation(Workspace.JobFitAssessment.Recommendation) - @Workspace.JobFitAssessment.OverallScore/100
                </div>
            </div>
        </summary>

        @if (isRefreshingFitReview && operationStartedAt is not null)
        {
            <div class="status-chip status-pending">Running @GetOperationElapsed()</div>
        }

        <p class="muted-text">This deterministic review maps source-backed job and company signals to imported evidence and your stored applicant differentiators.</p>

        <div class="button-row">
            <button class="secondary-button" @onclick="RefreshFitReviewAsync" disabled="@(!CanRunFitReview || isBusy)">@(isRefreshingFitReview ? $"Running {GetOperationElapsed()}" : "Refresh fit review")</button>
        </div>

        <dl class="key-value-grid compact-grid">
            <dt>Recommendation</dt>
            <dd>@FormatRecommendation(Workspace.JobFitAssessment.Recommendation)</dd>
            <dt>Overall score</dt>
            <dd>@Workspace.JobFitAssessment.OverallScore / 100</dd>
            <dt>Requirements</dt>
            <dd>@Workspace.JobFitAssessment.Requirements.Count</dd>
            <dt>Strong matches</dt>
            <dd>@Workspace.JobFitAssessment.StrongMatchCount</dd>
            <dt>Open gaps</dt>
            <dd>@Workspace.JobFitAssessment.GapCount</dd>
        </dl>

        <div class="fit-assessment-list">
            @foreach (var requirement in Workspace.JobFitAssessment.Requirements)
            {
                <article class="fit-assessment-card @GetRequirementMatchClass(requirement.Match)">
                    <div class="fit-card-header">
                        <div>
                            <div class="field-label">@requirement.Category</div>
                            <h3>@requirement.Requirement</h3>
                        </div>
                        <div class="status-chip @GetRequirementStatusClass(requirement.Match)">
                            @FormatMatch(requirement.Match)
                        </div>
                    </div>
                    <p class="muted-text">Importance: @FormatImportance(requirement.Importance)</p>
                    <p>@requirement.Rationale</p>

                    @if (requirement.HasSourceContext)
                    {
                        <div class="stack-gap">
                            <div class="field-label">Extracted context</div>
                            <p class="muted-text">@FormatSourceContext(requirement)</p>
                            @if (!string.IsNullOrWhiteSpace(requirement.SourceSnippet))
                            {
                                <blockquote class="source-snippet">@requirement.SourceSnippet</blockquote>
                            }
                        </div>
                    }

                    @if (requirement.SupportingEvidence.Count > 0)
                    {
                        <div>
                            <div class="field-label">Supporting evidence</div>
                            <ul class="feature-list compact-list">
                                @foreach (var supportingEvidence in requirement.SupportingEvidence)
                                {
                                    <li>@supportingEvidence</li>
                                }
                            </ul>
                        </div>
                    }
                </article>
            }
        </div>
    </details>
}
else if (CanRunFitReview)
{
    <details class="card-panel stack-gap" open>
        <summary><h2>Fit review</h2></summary>

        @if (isRefreshingFitReview && operationStartedAt is not null)
        {
            <div class="status-chip status-pending">Running @GetOperationElapsed()</div>
        }

        <div class="button-row">
            <button class="secondary-button" @onclick="RefreshFitReviewAsync" disabled="@(!CanRunFitReview || isBusy)">@(isRefreshingFitReview ? $"Running {GetOperationElapsed()}" : "Refresh fit review")</button>
        </div>

        <p class="muted-text">No structured fit review is available for this tab yet. Run fit review or generate drafts when you want the app to score the current job context.</p>
    </details>
}

@if (Workspace.CandidateProfile is not null && Workspace.ActiveJobSet.TechnologyGapAssessment.HasSignals)
{
    <details class="card-panel stack-gap" open>
        <summary><h2>Technology gap check</h2></summary>

        @if (isRefreshingTechnologyGap && operationStartedAt is not null)
        {
            <div class="status-chip status-pending">Running @GetOperationElapsed()</div>
        }

        <p class="muted-text">This LLM-based check compares the current job context with profile skills, experience, projects, certifications, headline, summary, and manual notes.</p>

        <div class="button-row">
            <button class="secondary-button" @onclick="RefreshTechnologyGapAsync" disabled="@(!CanRunTechnologyGapCheck || isBusy)">@(isRefreshingTechnologyGap ? $"Running {GetOperationElapsed()}" : "Refresh technology gap check")</button>
        </div>

        <div>
            <div class="field-label">Detected in job context</div>
            <ul class="feature-list">
                @foreach (var technology in Workspace.ActiveJobSet.TechnologyGapAssessment.DetectedTechnologies)
                {
                    <li>@technology</li>
                }
            </ul>
        </div>

        <div>
            <div class="field-label">Possibly underrepresented on profile</div>
            @if (Workspace.ActiveJobSet.TechnologyGapAssessment.HasGaps)
            {
                <ul class="feature-list">
                    @foreach (var technology in Workspace.ActiveJobSet.TechnologyGapAssessment.PossiblyUnderrepresentedTechnologies)
                    {
                        <li>@technology might be underrepresented on the current profile.</li>
                    }
                </ul>
            }
            else
            {
                <p class="muted-text">No obvious technology gaps were detected for the active job tab.</p>
            }
        </div>
    </details>
}
else if (Workspace.JobPosting is not null)
{
    <details class="card-panel stack-gap" open>
        <summary><h2>Technology gap check</h2></summary>

        @if (isRefreshingTechnologyGap && operationStartedAt is not null)
        {
            <div class="status-chip status-pending">Running @GetOperationElapsed()</div>
        }

        <div class="button-row">
            <button class="secondary-button" @onclick="RefreshTechnologyGapAsync" disabled="@(!CanRunTechnologyGapCheck || isBusy)">@(isRefreshingTechnologyGap ? $"Running {GetOperationElapsed()}" : "Refresh technology gap check")</button>
        </div>

        <p class="muted-text">No LLM-based technology gap result is currently available for this job tab. Run the check when you want the app to inspect technology coverage.</p>
    </details>
}

@if (Workspace.EvidenceSelection.HasSignals)
{
    <details class="card-panel stack-gap" open>
        <summary>
            <div class="fit-header">
                <div>
                    <h2>Ranked evidence</h2>
                </div>
                <div class="status-chip @(Workspace.GetActiveSelectedEvidenceCount() > 0 ? "status-ok" : "status-pending")">
                    @Workspace.GetActiveSelectedEvidenceCount() selected
                </div>
            </div>
        </summary>

        <p class="muted-text">Select the strongest proof points to feed into the draft prompts for this job tab.</p>

        <div class="button-row">
            <button class="secondary-button" @onclick="SelectAllEvidenceAsync" disabled="@(Workspace.GetActiveSelectedEvidenceCount() == Workspace.EvidenceSelection.RankedEvidence.Count)">Select all</button>
            <button class="secondary-button" @onclick="ClearEvidenceSelectionsAsync" disabled="@(Workspace.GetActiveSelectedEvidenceCount() == 0)">Deselect all</button>
        </div>

        <div class="evidence-selection-list">
            @foreach (var rankedEvidence in Workspace.EvidenceSelection.RankedEvidence)
            {
                <label class="evidence-selection-card">
                    <input type="checkbox"
                           checked="@rankedEvidence.IsSelected"
                           @onchange="args => HandleEvidenceSelectionChanged(rankedEvidence.Evidence.Id, args)" />
                    <div class="evidence-selection-body">
                        <div class="fit-card-header">
                            <div>
                                <div class="field-label">@rankedEvidence.Evidence.Type</div>
                                <strong>@rankedEvidence.Evidence.Title</strong>
                            </div>
                            <div class="score-pill">@rankedEvidence.Score</div>
                        </div>
                        <p class="muted-text">@rankedEvidence.Evidence.Summary</p>
                        @if (rankedEvidence.Reasons.Count > 0)
                        {
                            <ul class="feature-list compact-list">
                                @foreach (var reason in rankedEvidence.Reasons)
                                {
                                    <li>@reason</li>
                                }
                            </ul>
                        }
                    </div>
                </label>
            }
        </div>
    </details>
}
else if (CanRunFitReview)
{
    <details class="card-panel stack-gap" open>
        <summary><h2>Ranked evidence</h2></summary>
        <p class="muted-text">No evidence ranking is available for this tab yet. It will be prepared when you run fit review or generate drafts.</p>
    </details>
}

<details class="card-panel stack-gap" open>
    <summary><h2>LLM + Drafts</h2></summary>

    @if ((isGenerating || isRefreshingAll) && operationStartedAt is not null)
    {
        <div class="status-chip status-pending">Running @GetOperationElapsed()</div>
    }

    <div class="status-chip @(Workspace.CanStartDraftGeneration ? "status-ok" : "status-pending")">
        @GetGenerationReadinessMessage()
    </div>
    <p class="muted-text">Saved applicant differentiators: @(Workspace.ApplicantDifferentiatorProfile.HasContent ? "Yes" : "No")</p>
    <p class="muted-text">Selected evidence items for this tab: @Workspace.GetActiveSelectedEvidenceCount()</p>

    <div class="button-row">
        <button class="secondary-button" @onclick="RefreshAllAnalysisAsync" disabled="@(isBusy || !Workspace.IsLlmReady)">@(isRefreshingAll ? $"Running {GetOperationElapsed()}" : "Refresh all analysis")</button>
    </div>

    @if (Workspace.OllamaAvailability is not null)
    {
        <dl class="key-value-grid">
            <dt>Version</dt>
            <dd>@Workspace.OllamaAvailability.Version</dd>
            <dt>Available models</dt>
            <dd>@Workspace.OllamaAvailability.AvailableModels.Count</dd>
            <dt>Loaded models</dt>
            <dd>@Workspace.OllamaAvailability.EffectiveRunningModels.Count</dd>
            <dt>Session model</dt>
            <dd>@(string.IsNullOrWhiteSpace(Workspace.SelectedLlmModel) ? "Not selected" : Workspace.SelectedLlmModel)</dd>
            <dt>Session model loaded</dt>
            <dd>@(Workspace.OllamaAvailability.IsModelLoaded(Workspace.SelectedLlmModel) ? "Yes" : "No")</dd>
            <dt>Thinking level</dt>
            <dd>@FormatThinkingLevel(Workspace.SelectedThinkingLevel)</dd>
        </dl>

        <p class="muted-text">Loaded now: @FormatLoadedModels(Workspace.OllamaAvailability)</p>
    }

    <label class="field-label" for="outputLanguage">Output language</label>
    <select id="outputLanguage" class="text-input" value="@Workspace.ActiveJobSet.OutputLanguage" @onchange="HandleOutputLanguageChanged">
        <option value="@OutputLanguage.English">English</option>
        <option value="@OutputLanguage.Danish">Danish</option>
    </select>

    <p class="muted-text">Danish output keeps technology names, company names, quoted job phrases, and file names in English or original form.</p>

    <div class="check-grid">
        <label><input type="checkbox" @bind="generateCv" /> CV</label>
        <label><input type="checkbox" @bind="generateCoverLetter" /> Cover letter</label>
        <label><input type="checkbox" @bind="generateSummary" /> Profile summary</label>
        <label><input type="checkbox" @bind="generateInterviewNotes" /> Interview notes</label>
    </div>

    <label class="field-label" for="additionalInstructions">Additional instructions</label>
    <textarea id="additionalInstructions" class="prompt-box" @bind="additionalInstructions"></textarea>

    <div class="button-row">
        <button class="primary-button" @onclick="GenerateDraftsAsync" disabled="@(isBusy || !Workspace.CanStartDraftGeneration)">@(isGenerating ? $"Running {GetOperationElapsed()}" : "Generate and export drafts")</button>
        <a class="secondary-button" href="/">Open Start / Setup</a>
    </div>

    @if (GetCurrentLlmTelemetry() is { } telemetry)
    {
        <div class="details-card stack-gap">
            <div class="field-label">Live LLM progress</div>
            <div class="sidebar-metric">@telemetry.Message</div>
            @if (!string.IsNullOrWhiteSpace(telemetry.Detail))
            {
                <p class="muted-text">@telemetry.Detail</p>
            }
            <dl class="key-value-grid compact-grid">
                <dt>Elapsed</dt>
                <dd>@FormatDuration(telemetry.Elapsed)</dd>
                @if (telemetry.PromptTokens is not null)
                {
                    <dt>Prompt</dt>
                    <dd>@FormatTokenCount(telemetry.PromptTokens)</dd>
                }
                @if (telemetry.CompletionTokens is not null)
                {
                    <dt>Completion</dt>
                    <dd>@FormatTokenCount(telemetry.CompletionTokens)</dd>
                }
                @if (telemetry.HasEstimatedRemaining)
                {
                    <dt>ETA</dt>
                    <dd>@FormatDuration(telemetry.EstimatedRemaining)</dd>
                }
            </dl>
            <div class="button-row">
                <a class="secondary-button" href="/diagnostics/session">Session diagnostics</a>
            </div>
        </div>
    }

    <p class="muted-text">Job parsing, company parsing, technology gap analysis, and generation use the session model you selected on Start / Setup. Fit scoring and evidence ranking stay deterministic after that context is stored.</p>

    @if (!CanRunFitReview)
    {
        <p class="muted-text">Load a profile and analyze a target job before running the fit review or evidence ranking.</p>
    }
    else if (!Workspace.ApplicantDifferentiatorProfile.HasContent)
    {
        <p class="muted-text">The fit review works without differentiators, but saving them on Start / Setup gives the app a stronger applicant narrative.</p>
    }

    @if (!CanRunTechnologyGapCheck)
    {
        <p class="muted-text">Load a profile and complete the session LLM setup before running the technology gap check or generation.</p>
    }
</details>

@if (Workspace.GeneratedDocuments.Count > 0)
{
    <details class="card-panel stack-gap" open>
        <summary><h2>Generated markdown drafts</h2></summary>
        @foreach (var document in Workspace.GeneratedDocuments)
        {
            <details class="details-card">
                <summary>@document.Kind - @document.Title</summary>
                <p class="muted-text">Created in @FormatDuration(document.LlmDuration)@(string.IsNullOrWhiteSpace(document.Model) ? string.Empty : $" via {document.Model}")@FormatTokenSummary(document)</p>
                <pre class="response-box">@document.Markdown</pre>
            </details>
        }
    </details>
}

@if (Workspace.Exports.Count > 0)
{
    <details class="card-panel stack-gap" open>
        <summary><h2>Exported markdown files</h2></summary>
        <ul class="feature-list">
            @foreach (var export in Workspace.Exports)
            {
                <li>@export.Kind: @export.MarkdownPath</li>
            }
        </ul>
    </details>
}

@code {
    private const string AnalyzeJobMessage = "Analyzing job page";
    private const string ParseJobTelemetryMessage = "Parsing job posting";
    private const string BuildCompanyContextMessage = "Building company context";
    private const string ParseCompanyTelemetryMessage = "Parsing company context";
    private const string GenerateDraftsMessage = "Generating targeted drafts";
    private const string GenerateDraftTelemetryPrefix = "Generating ";
    private const string RefreshFitReviewMessage = "Analyzing job fit";
    private const string RefreshTechnologyGapMessage = "Analyzing technology gaps";
    private string jobUrl = string.Empty;
    private string companyUrls = string.Empty;
    private string jobPostingText = string.Empty;
    private string companyContextText = string.Empty;
    private BusyOperation currentOperation;
    private DateTimeOffset? operationStartedAt;
    private System.Threading.Timer? uiRefreshTimer;
    private string? errorMessage;
    private JobPostingAnalysis? analysis;
    private CompanyResearchProfile? companyProfile;
    private string additionalInstructions = string.Empty;
    private bool generateCv = true;
    private bool generateCoverLetter = true;
    private bool generateSummary = true;
    private bool generateInterviewNotes = true;
    private bool isBusy => isResearching || isGenerating || isRefreshingFitReview || isRefreshingTechnologyGap || isRefreshingAll;
    private bool isResearching => currentOperation == BusyOperation.AnalyzeAndBuildContext || isAnalyzing || isBuildingCompanyContext;
    private bool isAnalyzing => currentOperation == BusyOperation.AnalyzeJob
        || IsCurrentWorkbenchOperation(AnalyzeJobMessage)
        || IsActiveTelemetryMessage(ParseJobTelemetryMessage);
    private bool isBuildingCompanyContext => currentOperation == BusyOperation.BuildCompanyContext
        || IsCurrentWorkbenchOperation(BuildCompanyContextMessage)
        || IsActiveTelemetryMessage(ParseCompanyTelemetryMessage);
    private bool isGenerating => currentOperation == BusyOperation.GenerateDrafts
        || IsCurrentWorkbenchOperation(GenerateDraftsMessage)
        || HasActiveTelemetryPrefix(GenerateDraftTelemetryPrefix);
    private bool isRefreshingFitReview => currentOperation == BusyOperation.RefreshFitReview
        || IsCurrentWorkbenchOperation(RefreshFitReviewMessage);
    private bool isRefreshingTechnologyGap => currentOperation == BusyOperation.RefreshTechnologyGap
        || IsCurrentWorkbenchOperation(RefreshTechnologyGapMessage)
        || IsActiveTelemetryMessage(RefreshTechnologyGapMessage);
    private bool isRefreshingAll => currentOperation == BusyOperation.RefreshAll;

    private bool CanRunFitReview => Workspace.CandidateProfile is not null && Workspace.JobPosting is not null;

    private bool CanRunTechnologyGapCheck => Workspace.IsLlmReady && Workspace.CandidateProfile is not null && Workspace.JobPosting is not null;

    protected override void OnInitialized()
    {
        Operations.Changed += HandleChanged;
        Workspace.Changed += HandleWorkspaceChanged;
        SyncFromWorkspace();
    }

    public void Dispose()
    {
        uiRefreshTimer?.Dispose();
        Operations.Changed -= HandleChanged;
        Workspace.Changed -= HandleWorkspaceChanged;
    }

    private void StartOperationTimer()
    {
        operationStartedAt = DateTimeOffset.Now;
        uiRefreshTimer?.Dispose();
        uiRefreshTimer = new System.Threading.Timer(_ => _ = InvokeAsync(StateHasChanged), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void StopOperationTimer()
    {
        operationStartedAt = null;
        uiRefreshTimer?.Dispose();
        uiRefreshTimer = null;
    }

    private string GetOperationElapsed()
        => operationStartedAt is not null
            ? FormatDuration(DateTimeOffset.Now - operationStartedAt.Value)
            : string.Empty;

    private async Task AnalyzeAndBuildContextAsync()
    {
        errorMessage = null;
        PersistJobSetInputs();
        StartOperationTimer();

        if (!TryEnsureResearchReadiness())
        {
            return;
        }

        if (Workspace.ActiveJobSet.InputMode == JobSetInputMode.PasteText)
        {
            await AnalyzeAndBuildContextFromTextAsync();
            return;
        }

        if (!TryGetJobUri(out var jobUri))
        {
            return;
        }

        if (!TryGetCompanyContextUris(out var companyContextUris))
        {
            return;
        }

        try
        {
            currentOperation = BusyOperation.AnalyzeAndBuildContext;
            Workspace.MarkLlmWorkStarted();

            if (!await ExecuteJobAnalysisAsync(jobUri, manageCurrentOperation: false, markLlmWorkStarted: false, emitSuccess: false, userErrorPrefix: "Job analysis"))
            {
                return;
            }

            if (!await ExecuteCompanyContextAsync(companyContextUris, manageCurrentOperation: false, markLlmWorkStarted: false, emitSuccess: false, userErrorPrefix: "Company context"))
            {
                return;
            }

            Operations.Success("Job and company context updated.", "The job tab now has the latest target role context and company context. Fit review and generation are still idle until you run them.");
            additionalInstructions = BuildResearchInstructions();
        }
        finally
        {
            currentOperation = BusyOperation.None;
            StopOperationTimer();
        }
    }

