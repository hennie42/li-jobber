    private async Task GenerateDraftsAsync()
    {
        errorMessage = null;
        currentOperation = BusyOperation.GenerateDrafts;
        StartOperationTimer();

        try
        {
            if (!Workspace.IsLlmReady)
            {
                errorMessage = "Complete Start / Setup first: check Ollama, choose a session model, and choose a thinking level.";
