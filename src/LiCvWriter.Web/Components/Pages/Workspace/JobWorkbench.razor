    private static string FormatSourceContext(JobRequirementAssessment requirement)
    {
        var segments = new List<string>();

        if (!string.IsNullOrWhiteSpace(requirement.SourceLabel))
        {
            segments.Add(requirement.SourceLabel);
        }

        if (requirement.SourceConfidence is not null)
        {
            segments.Add($"{requirement.SourceConfidence}% confidence");
        }

        return segments.Count == 0 ? "Source-backed extraction" : string.Join(" · ", segments);
    }

    private static string FormatLoadedModels(OllamaModelAvailability? availability)
    {
        if (availability is null)
        {
            return "Unknown";
        }

        return availability.EffectiveRunningModels.Count == 0
            ? "None reported"
            : string.Join(", ", availability.EffectiveRunningModels.Select(static model => model.Name));
    }

    private static string FormatDuration(TimeSpan? duration)
    {
        if (duration is null)
        {
            return "unknown time";
        }

        var value = duration.Value;
        return value.TotalMinutes >= 1
            ? value.ToString(@"m\:ss")
            : value.ToString(@"s\.f\s");
    }

    private static string FormatTokenSummary(GeneratedDocument document)
    {
        if (document.PromptTokens is null && document.CompletionTokens is null)
        {
            return string.Empty;
        }

        return $" ({document.PromptTokens ?? 0} prompt / {document.CompletionTokens ?? 0} completion tokens)";
    }

    private static string FormatTokenCount(long? tokens)
        => tokens?.ToString("N0") ?? "Pending";

    private LlmOperationTelemetry? GetCurrentLlmTelemetry()
        => IsWorkbenchTelemetryActive() ? Operations.ActiveLlmTelemetry : null;

    private bool IsWorkbenchTelemetryActive()
    {
        var telemetryMessage = Operations.ActiveLlmTelemetry?.Message;
        if (string.IsNullOrWhiteSpace(telemetryMessage))
        {
            return false;
        }

        return string.Equals(telemetryMessage, ParseJobTelemetryMessage, StringComparison.Ordinal)
            || string.Equals(telemetryMessage, ParseCompanyTelemetryMessage, StringComparison.Ordinal)
            || string.Equals(telemetryMessage, RefreshTechnologyGapMessage, StringComparison.Ordinal)
            || telemetryMessage.StartsWith(GenerateDraftTelemetryPrefix, StringComparison.Ordinal);
    }

    private bool IsCurrentWorkbenchOperation(string message)
        => Operations.IsBusy && string.Equals(Operations.CurrentMessage, message, StringComparison.Ordinal);

    private bool IsActiveTelemetryMessage(string message)
        => string.Equals(Operations.ActiveLlmTelemetry?.Message, message, StringComparison.Ordinal);

    private bool HasActiveTelemetryPrefix(string prefix)
        => Operations.ActiveLlmTelemetry?.Message.StartsWith(prefix, StringComparison.Ordinal) == true;

