    private async Task GenerateDraftsAsync()
    {
        errorMessage = null;
        currentOperation = BusyOperation.GenerateDrafts;
        StartOperationTimer();

        try
        {
            if (!Workspace.IsLlmReady)
            {
                errorMessage = "Complete Start / Setup first: check Ollama, choose a session model, and choose a thinking level.";
                return;
            }

            if (Workspace.CandidateProfile is null || Workspace.JobPosting is null)
            {
                errorMessage = "Load a LinkedIn profile and analyze a target job before generating drafts.";
                return;
            }

            var kinds = new List<DocumentKind>();
            if (generateCv) kinds.Add(DocumentKind.Cv);
            if (generateCoverLetter) kinds.Add(DocumentKind.CoverLetter);
            if (generateSummary) kinds.Add(DocumentKind.ProfileSummary);
            if (generateInterviewNotes) kinds.Add(DocumentKind.InterviewNotes);

            if (kinds.Count == 0)
            {
                errorMessage = "Select at least one document type.";
                return;
            }

            Workspace.ClearGeneratedArtifacts();
            await TryRefreshFitReviewAsync(throwOnMissingReadiness: false);
            Workspace.MarkLlmWorkStarted();
            Workspace.MarkActiveJobSetRunning("Draft generation is running for this tab.");

            var result = await Operations.RunAsync(
                GenerateDraftsMessage,
                $"{kinds.Count} document types via {Workspace.SelectedLlmModel} into {Workspace.ActiveJobSet.OutputFolderName}",
                () => DraftGenerationService.GenerateAsync(new DraftGenerationRequest(
                    Workspace.CandidateProfile,
                    Workspace.JobPosting,
                    Workspace.CompanyProfile?.Summary,
                    additionalInstructions,
                    kinds,
                    ExportToFiles: true,
                    LlmModel: Workspace.SelectedLlmModel,
                    LlmThinkingLevel: Workspace.SelectedThinkingLevel,
                    ExportFolder: Workspace.ActiveJobSet.OutputFolderName,
                    OutputLanguage: Workspace.ActiveJobSet.OutputLanguage,
                    JobFitAssessment: Workspace.JobFitAssessment,
                    ApplicantDifferentiatorProfile: Workspace.ApplicantDifferentiatorProfile,
                        EvidenceSelection: Workspace.EvidenceSelection,
                        TechnologyGapAssessment: Workspace.ActiveJobSet.TechnologyGapAssessment),
                        ReportLlmProgress));

            Workspace.SetGeneratedDocuments(result.Documents, result.Exports);
                    await RefreshOllamaAvailabilitySilentlyAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Workspace.MarkActiveJobSetFailed("Draft generation failed for this tab.");
        }
        finally
        {
            currentOperation = BusyOperation.None;
            StopOperationTimer();
        }
    }

