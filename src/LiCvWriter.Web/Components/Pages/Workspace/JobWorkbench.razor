            JobRequirementImportance.MustHave => "Must-have",
            JobRequirementImportance.NiceToHave => "Nice-to-have",
            JobRequirementImportance.Cultural => "Cultural signal",
            _ => "Requirement"
        };

    private static string FormatMatch(JobRequirementMatch match)
        => match switch
        {
            JobRequirementMatch.Strong => "Strong match",
            JobRequirementMatch.Partial => "Partial match",
            _ => "Gap"
        };

    private static string GetRequirementMatchClass(JobRequirementMatch match)
        => match switch
        {
            JobRequirementMatch.Strong => "fit-strong",
            JobRequirementMatch.Partial => "fit-partial",
            _ => "fit-missing"
        };

    private static string GetRequirementStatusClass(JobRequirementMatch match)
        => match switch
        {
            JobRequirementMatch.Strong => "status-ok",
            JobRequirementMatch.Partial => "status-pending",
            _ => "status-error"
        };
}