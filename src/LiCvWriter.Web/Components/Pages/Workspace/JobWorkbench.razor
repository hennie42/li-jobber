    private void AddJobSet(JobSetInputMode inputMode)
    {
        var existingIds = Workspace.JobSets.Select(j => j.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
        Workspace.AddJobSet(inputMode, makeActive: false);
        var newJobSet = Workspace.JobSets.FirstOrDefault(j => !existingIds.Contains(j.Id));
        errorMessage = null;
        SyncFromWorkspace();

        if (newJobSet is not null && string.IsNullOrWhiteSpace(JobSetId))
        {
            Navigation.NavigateTo($"/workspace/job-workbench/{newJobSet.Id}");
        }
    }

