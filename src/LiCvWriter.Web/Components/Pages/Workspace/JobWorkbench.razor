    private bool TryGetJobUri(out Uri jobUri)
    {
        if (!Uri.TryCreate(jobUrl, UriKind.Absolute, out jobUri!))
        {
            errorMessage = "Please enter a valid absolute job URL.";
            return false;
        }

        return true;
    }

    private bool TryGetCompanyContextUris(out Uri[] companyContextUris)
    {
        companyContextUris = companyUrls
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(value => Uri.TryCreate(value, UriKind.Absolute, out var uri) ? uri : null)
            .Where(static uri => uri is not null)
            .Cast<Uri>()
            .ToArray();

        if (companyContextUris.Length == 0)
        {
            errorMessage = "Add at least one absolute company URL.";
            return false;
        }

        return true;
    }

