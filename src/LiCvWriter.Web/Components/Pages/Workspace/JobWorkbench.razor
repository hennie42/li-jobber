    private async Task RefreshAllAnalysisAsync()
    {
        errorMessage = null;
        PersistJobSetInputs();

        if (!TryEnsureResearchReadiness())
        {
            return;
        }

        currentOperation = BusyOperation.RefreshAll;
        StartOperationTimer();

        try
        {
            Workspace.MarkLlmWorkStarted();

            if (Workspace.ActiveJobSet.InputMode == JobSetInputMode.PasteText)
            {
                if (!string.IsNullOrWhiteSpace(jobPostingText))
                {
                    if (!await ExecuteJobTextAnalysisAsync(manageCurrentOperation: false, markLlmWorkStarted: false, emitSuccess: false, userErrorPrefix: "Job analysis"))
                    {
                        return;
                    }
                }

                if (!string.IsNullOrWhiteSpace(companyContextText))
                {
                    if (!await ExecuteCompanyContextFromTextAsync(manageCurrentOperation: false, markLlmWorkStarted: false, emitSuccess: false, userErrorPrefix: "Company context"))
                    {
                        return;
                    }
                }
            }
            else
            {
                if (TryGetJobUri(out var jobUri))
                {
                    if (!await ExecuteJobAnalysisAsync(jobUri, manageCurrentOperation: false, markLlmWorkStarted: false, emitSuccess: false, userErrorPrefix: "Job analysis"))
                    {
                        return;
                    }
                }

                if (TryGetCompanyContextUris(out var companyContextUris))
                {
                    if (!await ExecuteCompanyContextAsync(companyContextUris, manageCurrentOperation: false, markLlmWorkStarted: false, emitSuccess: false, userErrorPrefix: "Company context"))
                    {
                        return;
                    }
                }
            }

            await TryRefreshFitReviewAsync();
            await TryRefreshTechnologyGapAsync();

            Operations.Success("All analysis refreshed.", "Job, company, fit review, technology gap and evidence are current for this tab.");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Operations.Error("Refresh all failed.", exception.Message);
        }
        finally
        {
            currentOperation = BusyOperation.None;
            StopOperationTimer();
        }
    }

    private async Task TryRefreshFitReviewAsync(bool throwOnMissingReadiness = false)
    {
        if (!CanRunFitReview)
        {
            if (throwOnMissingReadiness)
            {
                throw new InvalidOperationException("Load a profile and analyze a target job before running the fit review.");
            }

            return;
        }

        try
        {
            Workspace.MarkActiveJobSetRunning("Fit review is running for this tab.");
            var refreshed = await Operations.RunAsync(
                RefreshFitReviewMessage,
                Workspace.ActiveJobSet.Title,
                () => Task.FromResult(JobFitWorkspaceRefreshService.RefreshActiveJobSet()));

            if (!refreshed)
            {
                if (throwOnMissingReadiness)
                {
                    throw new InvalidOperationException("Load a profile and analyze a target job before running the fit review.");
                }

                return;
            }

            Workspace.ResetActiveJobSetProgress("Fit review updated for this job tab. Markdown generation not started for this tab.");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Workspace.MarkActiveJobSetFailed("Fit review failed for this tab.");
            Operations.Error("Fit review failed.", exception.Message);
        }
    }

    private async Task TryRefreshTechnologyGapAsync(bool throwOnMissingReadiness = false)
    {
        if (!CanRunTechnologyGapCheck)
        {
            if (throwOnMissingReadiness)
            {
                throw new InvalidOperationException("Load a profile and complete Start / Setup before running the technology gap check.");
            }

            return;
        }

        try
        {
            Workspace.MarkLlmWorkStarted();
            Workspace.MarkActiveJobSetRunning("Technology gap analysis is running for this tab.");
            var assessment = await Operations.RunAsync(
                RefreshTechnologyGapMessage,
                Workspace.ActiveJobSet.Title,
                () => GapAnalysisService.AnalyzeAsync(
                    Workspace.CandidateProfile!,
                    Workspace.JobPosting!,
                    Workspace.CompanyProfile,
                    Workspace.SelectedLlmModel,
                    Workspace.SelectedThinkingLevel,
                    ReportLlmProgress));

            Workspace.SetActiveJobSetTechnologyGapAssessment(assessment);
            Workspace.ResetActiveJobSetProgress("Technology gap analysis completed. Markdown generation not started for this tab.");
            await RefreshOllamaAvailabilitySilentlyAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            Workspace.MarkActiveJobSetFailed("Technology gap analysis failed for this tab.");
            Operations.Error("Technology gap analysis failed.", exception.Message);
        }
    }

