    private string BuildResearchInstructions()
    {
        var lines = new List<string>();

        if (analysis is not null)
        {
            foreach (var signal in analysis.CulturalSignals)
            {
                lines.Add($"- Reflect the cultural signal: {signal}");
            }
        }

        if (companyProfile is not null)
        {
            foreach (var principle in companyProfile.GuidingPrinciples)
            {
                lines.Add($"- Align with this guiding principle: {principle}");
            }

            foreach (var signal in companyProfile.CulturalSignals)
            {
                if (analysis?.CulturalSignals.Contains(signal, StringComparer.OrdinalIgnoreCase) != true)
                {
                    lines.Add($"- Reflect the company cultural signal: {signal}");
                }
            }

            foreach (var differentiator in companyProfile.Differentiators)
            {
                lines.Add($"- Show awareness of company differentiator: {differentiator}");
            }
        }

        return lines.Count > 0
            ? "Tone and cultural alignment from research:\n" + string.Join("\n", lines)
            : string.Empty;
    }

    private void SyncFromWorkspace()
    {
        if (string.IsNullOrWhiteSpace(JobSetId))
        {
            return;
        }

        var jobSet = CurrentJobSet;
        analysis = jobSet.JobPosting;
        companyProfile = jobSet.CompanyProfile;
        jobUrl = jobSet.JobUrl;
        companyUrls = jobSet.CompanyUrlsText;
        jobPostingText = jobSet.JobPostingText;
        companyContextText = jobSet.CompanyContextText;
        additionalInstructions = jobSet.AdditionalInstructions;

        if (string.IsNullOrWhiteSpace(jobUrl) && analysis?.SourceUrl is not null)
        {
            jobUrl = analysis.SourceUrl.ToString();
        }
    }

