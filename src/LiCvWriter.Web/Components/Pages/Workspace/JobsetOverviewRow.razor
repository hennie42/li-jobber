@using LiCvWriter.Application.Models
@using System.IO

<div class="overview-row">
    <div class="overview-row-topline">
        <div class="overview-row-heading">
            <a class="overview-row-title" href="@($"/workspace/job-workbench/{JobSet.Id}")">
                <span class="@($"job-set-indicator job-set-indicator-{GetIndicatorState(JobSet.ProgressState)}")" aria-hidden="true"></span>
                <span>@JobSet.Title</span>
            </a>
            <div class="overview-row-meta">
                <span class="meta-chip">@FormatInputMode(JobSet.InputMode)</span>
                <span class="meta-chip">@JobSet.OutputFolderName</span>
                <span class="meta-chip">in: @FormatInputLanguage(JobSet.InputLanguage)</span>
                <span class="meta-chip">out: @JobSet.OutputLanguage</span>
            </div>
        </div>
        @if (JobSet.JobFitAssessment.HasSignals)
        {
            <div class="fit-score-badge" title="Fit score">
                <span class="fit-score-recommendation">@JobSet.JobFitAssessment.Recommendation</span>
                <span class="fit-score-value">@JobSet.JobFitAssessment.OverallScore<span>/100</span></span>
            </div>
        }
    </div>

    <div class="overview-row-status">
        @if (string.IsNullOrWhiteSpace(ReadinessMessage))
        {
            <span class="status-chip status-ok">Ready for LLM work</span>
        }
        else
        {
            <span class="status-chip status-warning">Not ready: @ReadinessMessage</span>
        }
        <span class="status-chip @GetProgressChipClass(JobSet.ProgressState)">@JobSet.ProgressState</span>
        @if (!string.IsNullOrWhiteSpace(JobSet.ProgressDetail))
        {
            <span class="muted-text">@JobSet.ProgressDetail</span>
        }
    </div>

    <div class="overview-row-signals">
        <div class="subtask-indicators">
            @foreach (var subtask in Subtasks)
            {
                var status = JobSet.GetSubtaskStatus(subtask);
                <span class="subtask-chip subtask-@GetSubtaskStatusClass(status)" title="@FormatSubtaskLabel(subtask): @status">@FormatSubtaskLabel(subtask)</span>
            }
        </div>
        @if (JobSet.Exports.Count > 0)
        {
            @foreach (var export in JobSet.Exports)
            {
                @if (!string.IsNullOrWhiteSpace(export.FilePath))
                {
                    <a class="meta-chip meta-chip-link" href="@LocalFileLinkBuilder.BuildFileUri(export.FilePath)" target="_blank" rel="noopener">@FormatDocumentKind(export.Kind): @Path.GetFileName(export.FilePath)</a>
                }
                else
                {
                    <span class="meta-chip">@FormatDocumentKind(export.Kind)</span>
                }
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public JobSetSessionState JobSet { get; set; } = default!;
    [Parameter] public string ReadinessMessage { get; set; } = string.Empty;

    private static readonly JobSetSubtask[] Subtasks =
    [
        JobSetSubtask.JobContext,
        JobSetSubtask.FitReview,
        JobSetSubtask.TechnologyGap,
        JobSetSubtask.DraftGeneration
    ];

    private static string GetIndicatorState(JobSetProgressState state) => state switch
    {
        JobSetProgressState.Done => "done",
        JobSetProgressState.Running => "running",
        JobSetProgressState.Failed => "failed",
        _ => "idle"
    };

    private static string GetProgressChipClass(JobSetProgressState state) => state switch
    {
        JobSetProgressState.Done => "status-ok",
        JobSetProgressState.Running => "status-pending",
        JobSetProgressState.Failed => "status-warning",
        _ => string.Empty
    };

    private static string FormatInputMode(JobSetInputMode mode) => mode switch
    {
        JobSetInputMode.PasteText => "Paste text",
        _ => "URLs"
    };

    private static string FormatInputLanguage(JobSetSourceLanguage language) => language switch
    {
        JobSetSourceLanguage.English => "English",
        JobSetSourceLanguage.Danish => "Danish",
        _ => "Auto"
    };

    private static string GetSubtaskStatusClass(JobSetSubtaskStatus status) => status switch
    {
        JobSetSubtaskStatus.Done => "done",
        JobSetSubtaskStatus.Running => "running",
        _ => "not-started"
    };

    private static string FormatSubtaskLabel(JobSetSubtask subtask) => subtask switch
    {
        JobSetSubtask.JobContext => "Context",
        JobSetSubtask.FitReview => "Fit",
        JobSetSubtask.TechnologyGap => "Gap",
        JobSetSubtask.DraftGeneration => "Drafts",
        _ => subtask.ToString()
    };

    private static string FormatDocumentKind(DocumentKind kind) => kind switch
    {
        DocumentKind.Cv => "CV",
        DocumentKind.CoverLetter => "Cover letter",
        DocumentKind.ProfileSummary => "Profile summary",
        DocumentKind.InterviewNotes => "Interview questions",
        _ => kind.ToString()
    };
}
