{
  "LinkedIn": {
    "PortabilityScope": "r_dma_portability_self_serve"
  },
  "JobDiscovery": {
    "Enabled": true,
    "DefaultProviderId": "jobindex",
    "PublicHttpsOnly": true,
    "MaxResultPages": 2,
    "ShortlistLimit": 12,
    "RequestDelayMilliseconds": 500,
    "Providers": [
      {
        "Id": "jobindex",
        "DisplayName": "Jobindex",
        "BaseUrl": "https://jobindex.dk",
        "SearchPath": "/jobsoegning/it/systemudvikling/storkoebenhavn",
        "QueryParameterName": "q",
        "LocationParameterName": "",
        "AllowedHosts": ["jobindex.dk", "www.jobindex.dk"]
      }
    ]
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434/api",
    "Model": "gemma4:26b",
    "StatusTimeoutSeconds": 30,
    "StreamingInactivitySeconds": 300,
    "UseChatEndpoint": true,
    "KeepAlive": "10m",
    "MaxOperationSeconds": 0,
    "Think": "high",
    "Temperature": 0.1
  },
  "Storage": {
    "WorkingRoot": "%LOCALAPPDATA%/LiCvWriter",
    "AuditRoot": "%LOCALAPPDATA%/LiCvWriter/Audit",
    "ExportRoot": "%LOCALAPPDATA%/LiCvWriter/Exports"
  },
  "Evidence": {
    "DefaultSelectedCount": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
