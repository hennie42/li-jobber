    "ExportRoot": "%LOCALAPPDATA%/LiCvWriter/Exports"
  },
  "Evidence": {
    "DefaultSelectedCount": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
